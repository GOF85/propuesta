<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Propuesta en Revisión - MICE Catering</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/professional.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      :root {
        --brand-primary: <%= proposal.brand_color || '#0066cc' %>;
      }
      .brand-bg { background-color: var(--brand-primary) !important; }
      
      .sticky-card {
        position: sticky;
        top: 20px;
        z-index: 40;
      }
    </style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">

<%- include('../partials/header-client') %>

<main class="flex-grow bg-[#F8FAFC] py-8 px-4 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-blue-100/30 rounded-full blur-3xl -mr-48 -mt-48"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-green-100/30 rounded-full blur-3xl -ml-48 -mb-48"></div>

  <div class="max-w-2xl mx-auto flex flex-col gap-6 relative z-10 transition-all duration-700 animate-in fade-in slide-in-from-bottom-8">
    
    <!-- Card de Estado: STICKY -->
    <div class="sticky-card bg-white/95 backdrop-blur-md rounded-[2.5rem] shadow-xl shadow-blue-900/5 p-10 border border-white relative overflow-hidden group">
      <div class="flex flex-col md:flex-row items-center md:items-end justify-between gap-6 mb-8">
        <% if (proposal.logo_url) { %>
          <div class="transition-transform hover:scale-105 duration-500 flex-shrink-0">
              <img src="<%= proposal.logo_url %>" alt="Client Logo" class="h-12 w-auto object-contain brightness-110">
          </div>
        <% } %>
        
        <div class="text-center md:text-right">
          <h1 class="text-2xl font-black text-gray-900 tracking-tighter uppercase leading-none">
            Estamos trabajando para ti
          </h1>
          <p class="text-[9px] font-black uppercase tracking-[0.2em] mt-2 opacity-80" style="color: var(--brand-primary)">
            Propuesta exclusiva para <%= proposal.client_name %>
          </p>
        </div>
      </div>

      <div class="absolute top-0 right-0 w-24 h-24 bg-gray-50 rounded-bl-full -mr-12 -mt-12 group-hover:bg-blue-50 transition-colors duration-500"></div>
      
      <div class="flex flex-col items-center md:items-start">
        <div class="flex-grow text-center md:text-left">
          <p class="text-xs text-gray-400 mb-6 leading-relaxed font-medium">
            <%= proposal.commercial_name %> está actualizando los detalles.
          </p>
          
          <div class="flex flex-wrap items-center justify-center md:justify-start gap-3">
            <div class="bg-white/50 px-3 py-1.5 rounded-xl border border-gray-100 flex items-center gap-2">
              <i data-lucide="file-text" class="w-3.5 h-3.5 text-[#31713D]"></i>
              <span class="text-[10px] font-black text-gray-900 uppercase tracking-tight"><%= proposal.custom_ref || '#' + proposal.id %></span>
            </div>
            <button onclick="location.reload()" 
                    class="bg-gray-900 hover:bg-black text-white font-black uppercase tracking-widest text-[9px] py-2 px-4 rounded-xl transition-all flex items-center gap-2 shadow-lg hover:scale-105 active:scale-95">
              <i data-lucide="refresh-cw" class="w-3 h-3"></i>
              Comprobar
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Card del Chat -->
    <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-blue-900/5 overflow-hidden border border-white flex flex-col h-[550px]">
      <div class="brand-bg p-6 text-white shrink-0 relative">
        <div class="absolute top-0 right-0 w-24 h-24 bg-white/10 rounded-full -mr-12 -mt-12 blur-2xl"></div>
        <div class="relative flex items-center gap-4">
          <div class="w-12 h-12 rounded-full border-2 border-white/30 overflow-hidden bg-white/20 relative">
            <% if (proposal.commercial_avatar) { %>
              <img src="<%= proposal.commercial_avatar %>" alt="Asesor" class="w-full h-full object-cover">
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center">
                <i data-lucide="user" class="w-6 h-6 text-white/70"></i>
              </div>
            <% } %>
            <div class="absolute bottom-0 right-0 w-3 h-3 bg-green-400 border-2 border-[#31713D] rounded-full"></div>
          </div>
          <div>
            <p class="text-[9px] font-black uppercase tracking-widest opacity-70 mb-0.5">Chat con Asesor</p>
            <h3 class="font-black text-base tracking-tighter leading-none"><%= proposal.commercial_name %></h3>
          </div>
        </div>
      </div>

      <div id="chat-messages" class="flex-1 overflow-y-auto p-6 space-y-4 bg-gray-50/50">
          <div class="flex justify-start">
            <div class="bg-white border border-gray-100 rounded-2xl rounded-tl-none p-4 shadow-sm max-w-[85%]">
              <p class="text-[10px] font-black text-[#31713D] uppercase tracking-widest mb-1"><%= proposal.commercial_name %></p>
              <p class="text-sm text-gray-600 leading-relaxed font-medium">Hola <%= proposal.client_name %>, estoy ajustando los detalles de tu menú. ¿Tienes alguna duda mientras termino?</p>
            </div>
          </div>
      </div>

      <div class="p-6 bg-white border-t border-gray-100">
        <div class="relative flex items-center">
          <input type="text" id="chat-input" 
                 placeholder="Escribe aquí tu duda..." 
                 class="w-full bg-gray-50 border border-gray-100 rounded-2xl pl-5 pr-14 py-4 text-sm focus:outline-none focus:ring-4 focus:ring-brand-primary/5 focus:border-[#31713D]/20 transition-all font-medium">
          <button id="btn-send-message" 
                  class="absolute right-2 bg-gray-900 text-white w-10 h-10 rounded-xl flex items-center justify-center hover:scale-105 active:scale-95 transition-all shadow-lg hover:bg-black group">
            <i data-lucide="send" class="w-4 h-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"></i>
          </button>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer-client') %>

<script>
  window.clientProposalHash = "<%= proposal.unique_hash %>";
  window.proposalId = "<%= proposal.id %>";
  window.proposalHash = "<%= proposal.unique_hash %>";
  window.commercialAvatar = "<%= proposal.commercial_avatar %>";
</script>
<script src="/js/client-proposal.js" defer></script>
<script src="https://unpkg.com/lucide@latest"></script>
<script>
  window.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
  });
</script>
</body>
</html>
