      </p>

      <div class="space-y-3 w-full">
        <button id="btn-modal-venue-confirm" 
                class="w-full py-4 text-white font-black uppercase tracking-widest text-xs rounded-none transition-all shadow-xl hover:brightness-110 active:scale-95 transform"
                style="background-color: var(--brand-primary)">
          SÍ, CONFIRMAR SELECCIÓN
        </button>
        <button onclick="closeConfirmVenueModal()" class="w-full py-3 text-black font-bold text-[10px] uppercase tracking-widest hover:text-gray-600 transition-colors">
          CANCELAR
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal: Detalles del Venue -->
<div id="modal-venue-details" class="fixed inset-0 bg-black/60 hidden flex items-center justify-center z-[60] p-4 backdrop-blur-md">
  <div class="bg-white rounded-none shadow-2xl max-w-5xl w-full h-[85vh] overflow-hidden flex flex-col md:flex-row transform transition-all border border-white/20">
    <!-- Left Column: Carousel (50%) + Map (50%) -->
    <div class="w-full md:w-1/2 h-full flex flex-col bg-gray-100 border-r border-black">
      <!-- Top 50%: Image Carousel -->
      <div class="h-1/2 relative bg-gray-900 group overflow-hidden">
        <div id="modal-venue-carousel" class="flex h-full w-full transition-transform duration-500 ease-out">
           <!-- Imágenes inyectadas vía JS -->
        </div>
        
        <!-- Navigation Arrows -->
        <button onclick="prevVenueImage()" class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/90 backdrop-blur p-2 rounded-none text-white hover:text-gray-900 transition-all shadow-lg opacity-0 group-hover:opacity-100 z-20">
          <i data-lucide="chevron-left" class="w-6 h-6"></i>
        </button>
        <button onclick="nextVenueImage()" class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/90 backdrop-blur p-2 rounded-none text-white hover:text-gray-900 transition-all shadow-lg opacity-0 group-hover:opacity-100 z-20">
          <i data-lucide="chevron-right" class="w-6 h-6"></i>
        </button>

        <!-- Counter Indicator -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 bg-black/50 backdrop-blur-md px-4 py-1.5 rounded-none border border-white/10 flex items-center gap-2 z-20">
          <span id="carousel-current" class="text-white font-black text-xs">1</span>
          <span class="text-white/40 font-bold text-[10px]">/</span>
          <span id="carousel-total" class="text-white/60 font-bold text-xs">0</span>
        </div>
      </div>

      <!-- Bottom 50%: Operational Map -->
      <div class="h-1/2 relative">
        <div id="modal-venue-map-container" class="w-full h-full bg-gray-50">
          <iframe id="modal-venue-map" width="100%" height="100%" style="border:0;" src="" allowfullscreen="" loading="lazy"></iframe>
        </div>
        <div class="absolute top-4 left-4 z-10 pointer-events-none">
          <div class="bg-white/90 backdrop-blur px-3 py-1.5 rounded-none shadow-lg border border-black0 flex items-center gap-2">
            <i data-lucide="map-pin" class="w-3.5 h-3.5 text-blue-500"></i>
            <span class="text-[9px] font-black uppercase tracking-widest text-gray-700">Ubicación</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Info Side -->
    <div class="w-full md:w-1/2 flex flex-col h-full bg-white">
      <!-- Header -->
      <div class="relative border-b border-black">
        <button onclick="closeVenueModal()" class="absolute top-4 right-4 z-20 p-2 bg-white hover:bg-red-50 hover:text-red-500 transition-all border border-black">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>

        <div class="p-4 md:p-5 bg-gray-50 border-b border-black/20">
          <div class="grid grid-cols-3 gap-2 md:gap-3 items-stretch pr-12">
            <% if (!isLocked) { %>
              <button id="btn-confirm-select-venue" class="col-span-1 h-11 bg-[#31713D] text-white font-black uppercase tracking-[0.12em] text-[10px] md:text-[11px] border border-black shadow-md hover:brightness-110 transition-all active:scale-[0.99] flex items-center justify-center gap-2">
                <i data-lucide="check-circle" class="w-4 h-4 md:w-4.5 md:h-4.5"></i>
                <span>ELEGIR</span>
              </button>
            <% } %>

            <button onclick="navigateVenue(-1)" class="venue-nav-btn h-11 bg-white border border-black text-gray-700 text-[10px] md:text-[11px] font-black uppercase tracking-widest hover:bg-gray-100 transition-all flex items-center justify-center gap-1.5">
              <i data-lucide="arrow-left" class="w-4 h-4"></i>
              <span>Anterior</span>
            </button>

            <button onclick="navigateVenue(1)" class="venue-nav-btn h-11 bg-gray-900 text-white border border-black text-[10px] md:text-[11px] font-black uppercase tracking-widest hover:bg-black transition-all flex items-center justify-center gap-1.5">
              <span>Siguiente</span>
              <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
          </div>
        </div>

        <div class="p-6 md:p-8 md:pb-5">
          <div class="space-y-1.5">
            <div class="flex items-center gap-2">
              <span class="text-[10px] uppercase font-black tracking-[0.3em] text-[#31713D]">Detalles del Espacio</span>
              <span id="modal-venue-counter" class="bg-gray-100 text-black text-[10px] px-2 py-0.5 rounded-none font-bold">1 / 3</span>
            </div>
            <h2 id="modal-venue-title" class="text-3xl md:text-4xl font-black text-gray-900 leading-none tracking-tighter">
              Nombre del Venue
            </h2>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="flex-1 overflow-y-auto px-6 md:px-8 py-5 space-y-5">
        <div class="space-y-2">
          <p class="text-[10px] uppercase font-bold tracking-widest text-black">Descripción del Espacio</p>
          <p id="modal-venue-description" class="text-sm text-gray-600 leading-relaxed">
            ...
          </p>
        </div>

        <div id="modal-venue-link-container" class="space-y-3">
           <a id="modal-venue-link" href="#" target="_blank" class="w-full py-4 bg-gray-900 text-white rounded-none font-bold flex items-center justify-center gap-3 hover:bg-black transition-all shadow-xl border border-black">
             <i data-lucide="external-link" class="w-5 h-5 text-blue-400"></i>
             Ver en micecatering.com
           </a>
        </div>

        <div id="modal-venue-address-container" class="space-y-2 bg-gray-50 p-6 rounded-none border border-black">
          <p class="text-[10px] uppercase font-bold tracking-widest text-black">Dirección</p>
          <div class="flex items-start gap-3">
             <i data-lucide="map-pin" class="w-5 h-5 text-blue-500 mt-0.5"></i>
             <p id="modal-venue-address" class="text-sm font-bold text-gray-800">
               Cargando dirección...
             </p>
          </div>
        </div>
      </div>
      
      <!-- Footer -->
      <div class="px-6 md:px-8 py-4 border-t border-black bg-gray-50/70">
        <p class="text-[9px] italic text-black text-center mb-0 leading-tight">
          La disponibilidad está sujeta a confirmación final por parte del espacio.
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Modal: Zoom de Imágenes (Lightbox) -->
<div id="modal-venue-zoom" class="fixed inset-0 bg-black/95 hidden z-[70] flex flex-col items-center justify-center p-4 md:p-12 backdrop-blur-sm">
  <!-- Close Button -->
  <button onclick="closeVenueZoom()" class="absolute top-6 right-6 text-white/50 hover:text-white transition-colors p-2 z-[80]">
    <i data-lucide="x" class="w-10 h-10"></i>
