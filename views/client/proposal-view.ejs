<script>
  // Intersection Observer globally defined
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, observerOptions);

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

    const summaryProgress = document.getElementById('summary-progress-bar');
    const floatingProgress = document.getElementById('progress-bar-fill');
    const initialProgress = Number(summaryProgress?.dataset.initialProgress || floatingProgress?.dataset.initialProgress || 0);

    if (summaryProgress) {
      summaryProgress.style.width = `${initialProgress}%`;
    }

    if (floatingProgress) {
      floatingProgress.style.width = `${initialProgress}%`;
    }
    
    // Lucide Icons refresh
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  });

  // Estado Global Galería
  let currentGalleryImages = [];
  let currentGalleryIndex = 0;

  window.openGalleryAt = function(index) {
      currentGalleryIndex = index;
      updateGalleryModal();
      document.getElementById('gallery-carousel-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
  };

  window.closeGalleryModal = function() {
      document.getElementById('gallery-carousel-modal').classList.add('hidden');
      if (
        !document.getElementById('service-menu-modal').classList.contains('hidden') ||
        !document.getElementById('video-preview-modal').classList.contains('hidden')
      ) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
  };

  window.openVideoModal = function(videoUrl) {
    const modal = document.getElementById('video-preview-modal');
    const player = document.getElementById('video-preview-player');
    if (!modal || !player || !videoUrl) return;
    player.src = videoUrl;
    player.load();
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    const playPromise = player.play();
    if (playPromise && typeof playPromise.catch === 'function') {
      playPromise.catch(() => {});
    }
  };

  window.closeVideoModal = function() {
    const modal = document.getElementById('video-preview-modal');
    const player = document.getElementById('video-preview-player');
    if (player) {
      player.pause();
      player.removeAttribute('src');
      player.load();
    }
    if (modal) modal.classList.add('hidden');

    const isMenuOpen = !document.getElementById('service-menu-modal').classList.contains('hidden');
    const isGalleryOpen = !document.getElementById('gallery-carousel-modal').classList.contains('hidden');
    document.body.style.overflow = (isMenuOpen || isGalleryOpen) ? 'hidden' : '';
  };

  function updateGalleryModal() {
      const img = currentGalleryImages[currentGalleryIndex];
      const mainImg = document.getElementById('carousel-main-image');
      
      mainImg.style.opacity = '0';
      setTimeout(() => {
          mainImg.src = img.src;
          document.getElementById('carousel-image-title').innerText = img.title || '';
          document.getElementById('carousel-image-desc').innerText = img.description || '';
          document.getElementById('carousel-counter').innerText = `${currentGalleryIndex + 1} / ${currentGalleryImages.length}`;
          mainImg.style.opacity = '1';
      }, 200);
  }

  window.nextGalleryImage = function() {
      currentGalleryIndex = (currentGalleryIndex + 1) % currentGalleryImages.length;
      updateGalleryModal();
  };

  window.prevGalleryImage = function() {
      currentGalleryIndex = (currentGalleryIndex - 1 + currentGalleryImages.length) % currentGalleryImages.length;
      updateGalleryModal();
  };

  window.openMenuModal = function(input) {
    try {
        let opt;
        let serviceTitle = '';
        let serviceDate = '';
        let servicePaxAttr = null;
        let servicePricePaxAttr = null;
        if (input instanceof HTMLElement) {
            opt = JSON.parse(input.getAttribute('data-menu'));
            serviceTitle = input.getAttribute('data-service-title') || '';
            serviceDate = input.getAttribute('data-service-date') || '';
            servicePaxAttr = input.getAttribute('data-service-pax');
            servicePricePaxAttr = input.getAttribute('data-service-price-pax');
        } else {
            opt = typeof input === 'string' ? JSON.parse(input) : input;
        }

        const parseNumeric = (val) => {
          if (val === null || val === undefined || val === '') return NaN;
          const normalized = String(val).replace(',', '.').replace(/[^0-9.-]/g, '');
          return Number(normalized);
        };

        const defaultPax = Number('<%= proposal.pax || 0 %>') || 0;
        const parsedPaxFromAttr = parseNumeric(servicePaxAttr);
        const resolvedPax = Number.isFinite(parsedPaxFromAttr) && parsedPaxFromAttr > 0 ? parsedPaxFromAttr : defaultPax;

        const parsedPriceFromOption = parseNumeric(opt?.price_pax);
        const parsedPriceFromAttr = parseNumeric(servicePricePaxAttr);
        const resolvedPricePax = Number.isFinite(parsedPriceFromOption)
          ? parsedPriceFromOption
          : (Number.isFinite(parsedPriceFromAttr) ? parsedPriceFromAttr : 0);

        // Almacenar datos para el chat predefinido
        window.currentModalService = {
          menuName: opt.name,
          serviceTitle: serviceTitle,
          serviceDate: serviceDate,
          pax: resolvedPax,
          pricePax: resolvedPricePax
        };

        const modal = document.getElementById('service-menu-modal');
        const content = document.getElementById('menu-modal-content');
        
        // Preparar imágenes para galería global
        currentGalleryImages = [];
        if (opt.items && opt.items.length > 0) {
            opt.items.forEach(item => {
                if (item.image_url) {
                    currentGalleryImages.push({
                        src: item.image_url,
                        title: item.name,
                        description: item.description
                    });
                }
            });
        }
        // Añadir imágenes principales del menú si no están
        if (opt.images && opt.images.length > 0) {
            opt.images.forEach(img => {
                if (!currentGalleryImages.find(c => c.src === img)) {
                    currentGalleryImages.push({ src: img, title: opt.name, description: '' });
                }
            });
        }

        let badgesHtml = (opt.badges || []).map(b => `<span class="bg-[#31713D] text-white px-4 py-1.5 text-[9px] font-black uppercase tracking-[0.2em] shadow-sm">${b}</span>`).join('');
        
        const formatMoney = (val) => new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(val);

        // Ajuste dinámico de tamaño de fuente para el título (Aún más compacto)
        const nameLength = (opt.name || '').length;
        let titleSizeClass = "text-2xl md:text-4xl";
        if (nameLength > 25) titleSizeClass = "text-xl md:text-3xl";
        
        // Galería de imágenes (columnas adaptativas + altura compacta)
        const imageCount = (opt.images || []).length;
        const desktopColsClass = imageCount >= 4
          ? 'md:grid-cols-4'
          : (imageCount === 3 ? 'md:grid-cols-3' : (imageCount === 2 ? 'md:grid-cols-2' : 'md:grid-cols-1'));
        const normalizedVideoUrl = (opt.video_url || '').trim();
        const hasVideo = normalizedVideoUrl.length > 0;
        const galleryWidthClass = hasVideo ? 'w-full' : 'max-w-4xl mx-auto';

        let galleryHtml = imageCount > 0 ? `
          <div class="grid grid-cols-2 ${desktopColsClass} auto-rows-fr gap-1 mb-2 overflow-hidden border border-black p-1 bg-gray-50 shadow-sm ${galleryWidthClass} h-full">
                ${opt.images.map((img, iIdx) => {
                    const globalIdx = currentGalleryImages.findIndex(c => c.src === img);
                    return `
                    <div class="h-[140px] md:h-[160px] overflow-hidden border border-black group cursor-zoom-in" onclick="openGalleryAt(${globalIdx >= 0 ? globalIdx : 0})">
                        <img src="${img}" class="w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-110">
                    </div>`;
                }).join('')}
            </div>` : '';

        const videoPreviewHtml = hasVideo ? `
          <div class="border border-black bg-gray-50 p-1.5 h-full min-h-[170px] md:min-h-[176px] flex flex-col shadow-sm">
            <div class="flex items-center justify-between mb-1.5 px-0.5">
              <span class="text-[9px] font-black uppercase tracking-[0.2em] text-[#31713D]">Video</span>
              <span class="text-[8px] font-black uppercase tracking-widest text-black/40">Click para ampliar</span>
            </div>
            <button type="button" onclick="openVideoModal('${normalizedVideoUrl.replace(/'/g, "\\'")}')" class="group relative flex-1 min-h-[130px] md:min-h-[160px] bg-black border border-black/20 overflow-hidden cursor-pointer">
              <video src="${normalizedVideoUrl}" class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity" muted preload="metadata" playsinline></video>
              <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                <span class="w-10 h-10 rounded-full bg-black/55 border border-white/30 flex items-center justify-center text-white">
                  <i data-lucide="play" class="w-4.5 h-4.5 ml-0.5"></i>
                </span>
              </div>
            </button>
          </div>
        ` : '';

        const mediaBlockHtml = hasVideo
          ? `<div class="grid grid-cols-1 lg:grid-cols-[minmax(0,4fr)_minmax(260px,1fr)] gap-2 items-stretch">${galleryHtml || '<div class="h-full border border-black bg-gray-50 shadow-sm"></div>'}${videoPreviewHtml}</div>`
          : galleryHtml;

        let detailsHtml = '';
        if (opt.items && opt.items.length > 0) {
            // Agrupar items por categoría
            const groupedItems = opt.items.reduce((acc, item) => {
                const cat = item.category || 'Otros';
                if (!acc[cat]) acc[cat] = [];
                acc[cat].push(item);
                return acc;
            }, {});

            detailsHtml = Object.entries(groupedItems).map(([category, items]) => {
                const itemsHtml = items.map((item, idx) => {
                    const hasAllergens = (item.allergens || []).length > 0;
                    const allergensHtml = hasAllergens ? `
                        <div class="absolute bottom-full left-0 mb-4 hidden group-hover/desc:block z-50 animate-fadeIn bg-white border border-black p-4 shadow-2xl min-w-[280px]">
                            <div class="flex items-center gap-2 mb-3 pb-2 border-b border-black/5">
                                <i data-lucide="info" class="w-3 h-3 text-[#31713D]"></i>
                                <span class="text-[9px] font-black uppercase tracking-widest text-[#31713D]">Información de Alérgenos</span>
                            </div>
                            <div class="grid grid-cols-2 gap-3">
                                ${item.allergens.map(all => `
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 flex items-center justify-center bg-gray-100 border border-gray-200">
                                            <img src="/img/allergens/${all.toLowerCase().replace(/\s/g, '')}.png" class="w-5 h-5 object-contain" onerror="this.parentElement.style.display='none'">
                                        </div>
                                        <span class="text-[10px] font-bold text-gray-800 uppercase tracking-tighter">${all}</span>
                                    </div>`).join('')}
                            </div>
                        </div>` : `
                        <div class="absolute bottom-full left-0 mb-4 hidden group-hover/desc:block z-50 animate-fadeIn bg-white border border-black p-4 shadow-2xl min-w-[240px]">
                            <div class="flex items-center gap-2">
                                <i data-lucide="shield-check" class="w-4 h-4 text-[#31713D]"></i>
                                <span class="text-[10px] font-black uppercase tracking-widest text-[#31713D]">No contiene alérgenos declarados</span>
                            </div>
                        </div>`;

                    const globalIdx = currentGalleryImages.findIndex(c => c.src === item.image_url);

                    return `
                        <div class="py-2 border-b border-gray-100 last:border-0 hover:bg-gray-50/50 transition-colors group/item">
                          <div class="flex items-center gap-3">
                                ${item.image_url ? `
                              <div class="w-10 h-10 flex-shrink-0 border border-black/10 overflow-hidden cursor-zoom-in" onclick="openGalleryAt(${globalIdx})">
                                        <img src="${item.image_url}" class="w-full h-full object-cover group-hover/item:scale-110 transition-transform duration-700">
                                    </div>
                                ` : `
                                    <div class="w-2 flex-shrink-0 h-2 bg-[#31713D]/40"></div>
                                `}
                                <div class="flex-1 min-w-0">
                                    <h5 class="text-[12px] md:text-[13px] font-black text-gray-900 uppercase tracking-tight leading-none mb-0.5">${item.name}</h5>
                                    ${item.description ? `
                                        <div class="relative group/desc max-w-2xl cursor-help">
                                        <p class="service-item-description text-[10px] md:text-[11px] text-gray-500 italic font-medium leading-tight whitespace-pre-line break-words">${item.description}</p>
                                            ${allergensHtml}
                                        </div>` : ''}
                                </div>
                            </div>
                        </div>`;
                }).join('');

                return `
                    <div class="mb-4 last:mb-0 bg-white border border-black/10 p-3 md:p-4 shadow-sm">
                      <div class="flex items-center gap-3 mb-2">
                        <h6 class="text-[10px] md:text-[11px] font-black uppercase tracking-[0.28em] text-[#31713D] border-b-2 border-[#31713D] pb-1">
                                ${category}
                            </h6>
                        </div>
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6">
                            ${itemsHtml}
                        </div>
                    </div>`;
            }).join('');
        }

        content.innerHTML = `
                <div class="bg-gray-50 p-4 md:p-6 pr-16 md:pr-20 border-b border-black">
                <div class="max-w-6xl mx-auto">
                    <div class="flex gap-1.5 mb-2">${badgesHtml}</div>
                    
                    <div class="flex flex-col md:flex-row md:items-end justify-between gap-2 mb-2">
                        <h2 class="${titleSizeClass} font-black italic tracking-tighter uppercase leading-[0.9] text-gray-900 transition-all break-words">${opt.name}</h2>
                    </div>
                    
                    <div class="flex flex-col md:flex-row md:items-start justify-between gap-3">
                        <div class="flex-1">
                        ${opt.description ? `<p class="text-[12px] md:text-[14px] text-gray-700 italic font-medium leading-snug max-w-4xl border-l-2 border-[#31713D] pl-3 py-0.5 whitespace-pre-line">${opt.description}</p>` : ''}
                        </div>

                        <div class="shrink-0 w-full md:w-auto md:min-w-[240px] space-y-2">
                          <div class="bg-white border border-black px-4 py-2.5 shadow-sm">
                            <span class="text-[9px] font-black text-black uppercase tracking-[0.18em] block mb-1 leading-none">${window.currentModalService.pax} ASISTENTES</span>
                            <div class="text-[12px] text-gray-700 font-bold mb-1.5 leading-none">${formatMoney(window.currentModalService.pricePax)} <small class="text-[9px] text-gray-600">/u</small></div>
                            <div>
                              <span class="text-[9px] font-black text-black uppercase tracking-[0.18em] block mb-1 leading-none">SUBTOTAL SERVICIO</span>
                              <span class="text-xl md:text-2xl font-black text-[#31713D] tracking-tighter leading-none">
                                ${formatMoney(window.currentModalService.pricePax * window.currentModalService.pax)}
                              </span>
                            </div>
                          </div>

                          ${opt.url_images ? `
                          <a href="${opt.url_images}" target="_blank" class="w-full flex items-center justify-center gap-2 bg-white border border-black px-3 py-2 hover:bg-[#31713D] hover:text-white hover:border-[#31713D] transition-all group/link shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-0.5 hover:translate-y-0.5 relative overflow-hidden">
                            <i data-lucide="camera" class="w-4 h-4 text-[#31713D] group-hover/link:text-white transition-colors"></i>
                            <span class="text-[9px] font-black uppercase tracking-[0.18em] leading-none">Ver Álbum · Galería</span>
                          </a>
                          ` : ''}
                        </div>
                    </div>
                </div>
            </div>
                <div class="p-4 md:p-6 bg-white min-h-[28vh]">
                <div class="max-w-7xl mx-auto">
                  ${mediaBlockHtml}
                    <div class="mt-4">
                        ${detailsHtml}
                    </div>
                </div>
            </div>
            
            <!-- Footer compacto: solo acción de chat -->
                <div class="px-5 py-3 border-t border-gray-100 bg-gray-50 flex items-center justify-end">
              <div onclick="window.contactConsultantFromMenu()" 
                 class="group inline-flex items-center gap-3 cursor-pointer">
                <div class="relative">
                  <div class="w-9 h-9 bg-[#31713D] rounded-none flex items-center justify-center text-white shadow-lg group-hover:scale-110 transition-transform">
                    <i data-lucide="message-circle" class="w-4.5 h-4.5"></i>
                  </div>
                </div>
                <div class="text-left">
                  <p class="text-[9px] font-black uppercase tracking-widest text-[#31713D] mb-0.5">Consultar dudas</p>
                  <p class="text-sm font-bold text-gray-900 leading-none">Hablar con tu gestor</p>
                </div>
              </div>
            </div>
        `;

        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        if (window.lucide) lucide.createIcons();
    } catch (e) {
        console.error("Error opening menu modal:", e);
    }
  };

  window.closeMenuModal = function() {
    document.getElementById('service-menu-modal').classList.add('hidden');
    if (
      document.getElementById('gallery-carousel-modal').classList.contains('hidden') &&
      document.getElementById('video-preview-modal').classList.contains('hidden')
    ) {
      document.body.style.overflow = '';
    }
  };
</script>

<!-- 🏁 FLOATING CONFIRMATION BAR (UX UPGRADE) -->
<div id="floating-confirm-bar" class="fixed bottom-0 inset-x-0 z-[60] bg-white border-t-2 border-black transform translate-y-full transition-transform duration-500 shadow-[0_-10px_30px_rgba(0,0,0,0.18)] print:hidden">
  <div class="max-w-7xl mx-auto px-6 py-3 space-y-3">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] items-center gap-3 md:gap-6">
      <div class="flex items-center gap-3 md:gap-4 min-w-0">
        <span class="inline-flex items-center h-[34px] px-3 border border-green-200 bg-green-50 text-[#31713D] text-[9px] font-black uppercase tracking-widest whitespace-nowrap">
          Base imponible
        </span>
        <span id="floating-total" class="text-2xl md:text-3xl font-black text-[#31713D] tracking-tighter leading-none whitespace-nowrap"><%= formatCurrency(proposal.totals?.total_base_after_discount || 0) %></span>
        <span class="hidden md:inline text-[9px] font-black uppercase tracking-widest text-gray-400">(descuentos aplicados)</span>
      </div>
      <div class="flex items-center gap-2 md:gap-3 w-full md:w-auto justify-end">
        <button onclick="toggleSidebar()" class="flex-1 md:flex-none h-[42px] px-4 md:px-6 border border-black/20 text-black text-[9px] md:text-[10px] font-black uppercase tracking-widest hover:bg-gray-50 transition-all flex items-center justify-center gap-2">
          <i data-lucide="eye" class="w-4 h-4 text-[#31713D]"></i>
          <span>Revisar Elecciones</span>
        </button>
        <button id="btn-floating-accept" class="flex-1 md:flex-none h-[42px] px-5 md:px-8 bg-white text-black text-[10px] md:text-[11px] font-black uppercase tracking-[0.15em] shadow-2xl hover:bg-green-50 transition-all transform hover:-translate-y-0.5 active:scale-95 flex items-center justify-center gap-2 border-2 border-transparent hover:border-black">
          <i data-lucide="check-circle" class="w-5 h-5 text-green-600"></i>
          <span>Confirmar mi Propuesta</span>
        </button>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <div class="flex-1 bg-gray-200 h-1.5 overflow-hidden">
        <div id="progress-bar-fill" data-initial-progress="<%= initialProgressPercent %>" class="bg-amber-500 h-1.5 transition-all duration-500" style="width: 0%;"></div>
      </div>
      <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest whitespace-nowrap">Seguimiento</span>
    </div>
  </div>
</div>

<!-- 📋 SIDEBAR / SELECTION DRAWER (UX UPGRADE) -->
<div id="selection-sidebar-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[70] hidden transition-opacity duration-300 opacity-0" onclick="toggleSidebar()"></div>
<div id="selection-sidebar" class="fixed top-0 right-0 h-full w-full max-w-lg bg-white z-[80] shadow-2xl transform translate-x-full transition-transform duration-500 flex flex-col border-l border-black print:hidden">
  <!-- Sidebar Header -->
  <div class="brand-bg p-8 text-white relative">
    <button onclick="toggleSidebar()" class="absolute top-8 right-8 text-white/60 hover:text-white transition-colors">
      <i data-lucide="x" class="w-6 h-6"></i>
    </button>
    <div class="flex items-center gap-4 mb-2">
      <div class="w-12 h-12 bg-white/10 flex items-center justify-center border border-white/20 overflow-hidden">
        <% if (proposal.logo_url) { %>
          <img src="<%= proposal.logo_url %>" alt="<%= proposal.client_name %>" class="w-full h-full object-contain bg-white p-1" />
        <% } else { %>
          <i data-lucide="shopping-bag" class="w-6 h-6 text-green-400"></i>
        <% } %>
      </div>
      <div>
        <h2 class="text-2xl font-black tracking-tighter uppercase mb-0">Mi Selección</h2>
        <p class="text-[10px] font-bold text-white/50 uppercase tracking-widest leading-none">Resumen de tu evento</p>
      </div>
    </div>
  </div>

  <!-- Sidebar Content -->
  <div id="sidebar-choices-content" class="flex-1 overflow-y-auto p-8 space-y-8 bg-gray-50/50">
    <!-- Will be filled by JS: Venues + Selected Options -->
    <div class="animate-pulse space-y-4">
      <div class="h-20 bg-gray-200"></div>
      <div class="h-20 bg-gray-200"></div>
      <div class="h-20 bg-gray-200"></div>
    </div>
  </div>

  <!-- Sidebar Footer -->
  <div class="p-8 border-t border-black bg-white space-y-4 shadow-[0_-10px_30px_rgba(0,0,0,0.05)]">
    <div class="space-y-2">
      <div class="flex justify-between items-center">
        <span class="text-[11px] font-black text-gray-400 uppercase tracking-widest">Base Imponible</span>
        <span id="sidebar-base" class="text-3xl md:text-4xl font-black brand-text">0,00 €</span>
      </div>

      <div id="sidebar-discount-row" class="flex justify-between items-center brand-text" style="display:none;">
        <span class="text-[11px] font-black uppercase tracking-widest">Descuento</span>
        <span id="sidebar-discount" class="text-sm font-black">-0,00 €</span>
      </div>

      <div class="flex justify-between items-center">
        <span class="text-[11px] font-black text-gray-400 uppercase tracking-widest">IVA</span>
        <span id="sidebar-iva" class="text-sm font-bold text-gray-600">0,00 €</span>
      </div>

      <div class="border-t border-black mt-2 pt-3 flex justify-between items-end">
        <span class="text-[11px] font-bold uppercase text-gray-600">Total (IVA incl.)</span>
        <span id="sidebar-total" class="text-xl font-bold text-gray-700">0,00 €</span>
      </div>
    </div>
    <button id="btn-sidebar-accept" class="w-full brand-bg text-white py-5 text-sm font-black uppercase tracking-[0.2em] shadow-xl hover:brand-hover transition-all transform active:scale-95 flex items-center justify-center gap-4 group">
      <span>Confirmar Propuesta</span>
      <i data-lucide="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform"></i>
    </button>
    <button onclick="toggleChat(event)" class="w-full bg-white border border-black text-black py-4 text-[10px] font-black uppercase tracking-widest hover:bg-gray-50 transition-all flex items-center justify-center gap-3">
      <i data-lucide="message-circle" class="w-4 h-4 text-[#31713D]"></i>
      <span>Consultar dudas con mi asesor</span>
    </button>
  </div>
</div>

<%- include('../partials/footer-client') %>
</body>
</html>

