<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Propuesta de Catering - MICE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/professional.css">
    
    <!-- 🎨 INYECCIÓN DINÁMICA DE BRANDING -->
    <style>
      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Inter', sans-serif;
      }

      section {
        scroll-margin-top: 140px;
      }

      .hide-scrollbar::-webkit-scrollbar {
        display: none;
      }

      .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      :root {
        /* Colores dinámicos generados desde logo */
        --brand-primary: <%= brandPalette.primary %>;
        --brand-primary-rgb: <%= brandPalette.primaryRgb %>;
        --brand-hover: <%= brandPalette.hover %>;
        --brand-light: <%= brandPalette.light %>;
        --brand-dark: <%= brandPalette.dark %>;
        --brand-text: <%= brandPalette.text %>;
        --brand-complement: <%= brandPalette.complement %>;
      }

      /* Aplicar branding dinámico */
      .brand-bg { background-color: var(--brand-primary) !important; }
      .brand-bg-light { background-color: var(--brand-light) !important; }
      .brand-text { color: var(--brand-primary) !important; }
      .brand-contrast { color: var(--brand-text) !important; }
      .brand-border { border-color: var(--brand-primary) !important; }
      .brand-hover:hover { background-color: var(--brand-hover) !important; }
      
      /* Utilities para contraste dinámico */
      .group:hover .group-hover\:brand-contrast { color: var(--brand-text) !important; }
      .group:hover .group-hover\:brand-bg { background-color: var(--brand-primary) !important; }
      
      /* Botones con marca */
      .btn-brand {
        background-color: var(--brand-primary);
        color: var(--brand-text);
        border: none;
      }
      .btn-brand:hover {
        background-color: var(--brand-hover);
      }

      /* Animaciones para selección de menú */
      .menu-option-card {
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* Estilos para propuesta aceptada */
      .accepted-stamp {
        transform: rotate(-15deg);
        border: 4px solid #31713D;
        color: #31713D;
        display: inline-block;
        padding: 0.5rem 1rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        position: absolute;
        top: 2rem;
        right: 2rem;
        background: rgba(255, 255, 255, 0.9);
        z-index: 30;
        box-shadow: 0 0 20px rgba(49, 113, 61, 0.2);
      }
      
      .success-gradient {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
      }

      /* 🎬 WOW ANIMATIONS */
      @keyframes revealUp {
        0% { opacity: 0; transform: translateY(40px) scale(0.98); }
        100% { opacity: 1; transform: translateY(0) scale(1); }
      }

      @keyframes revealRight {
        0% { opacity: 0; transform: translateX(-30px); }
        100% { opacity: 1; transform: translateX(0); }
      }

      @keyframes slideInBar {
        0% { transform: scaleX(0); opacity: 0; }
        100% { transform: scaleX(1); opacity: 1; }
      }

      .reveal-wow {
        opacity: 0;
        animation: revealUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fadeIn {
        animation: fadeIn 0.3s ease-out forwards;
      }

      .stagger-1 { animation-delay: 0.1s; }
      .stagger-2 { animation-delay: 0.2s; }
      .stagger-3 { animation-delay: 0.3s; }
      .stagger-4 { animation-delay: 0.4s; }
      .stagger-5 { animation-delay: 0.5s; }

      .reveal-text {
        animation: revealRight 1s cubic-bezier(0.16, 1, 0.3, 1) both;
      }

      /* Blur effect on scroll preparation */
      .scroll-reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .scroll-reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Helpers visuales para acercar la UI a la referencia */
      .hero-print {
        border-radius: 0.75rem !important;
      }
      .hero-bg-layer {
        border-radius: 0.75rem !important;
      }
      .soft-card {
        border-radius: 0.75rem !important;
        overflow: hidden;
      }

      .service-item-description {
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 5;
        line-clamp: 5;
        overflow: hidden;
      }

      @media (min-width: 768px) {
        .service-item-description {
          display: block;
          -webkit-line-clamp: unset;
          line-clamp: unset;
          overflow: visible;
        }
      }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 antialiased pb-32">
    
    <%- include('../partials/header-client') %>

    <% 
      // Identificar venue seleccionado
      const selectedVenue = proposal.venues.find(v => v.is_selected);
      const otherVenues = proposal.venues.filter(v => !v.is_selected);
      
      // Helper para parsear imágenes de forma ultra-robusta
      const parseImages = (imgStr) => {
        if (!imgStr) return [];
        
        // Si ya es un array (parseado por el driver)
        if (Array.isArray(imgStr)) {
          return imgStr.map(img => (typeof img === 'string' ? img.replace(/[\n\r]/g, '').trim() : img)).filter(Boolean);
        }
        
        try {
          // Limpiar carácteres invisibles y saltos de línea
          const cleanStr = String(imgStr).replace(/[\n\r]/g, '').trim();
          
          // Caso 1: JSON estándar
          if (cleanStr.startsWith('[') || cleanStr.startsWith('{')) {
            const parsed = JSON.parse(cleanStr);
            if (Array.isArray(parsed)) {
              return parsed.map(img => (typeof img === 'string' ? img.replace(/[\n\r]/g, '').trim() : img)).filter(Boolean);
            }
          }
          
          // Caso 2: Lista separada por comas (fallback)
          if (cleanStr.includes('/uploads/')) {
             return cleanStr.split(',').map(s => s.trim().replace(/[\[\]"']/g, '')).filter(Boolean);
          }
        } catch (e) {
          // Silenciar error y usar fallback regex
        }
        
        // Fallback final: Búsqueda por regex de rutas de /uploads/
        const matches = String(imgStr).match(/\/uploads\/[^"'\s,\]]+/g);
        if (matches) {
          return matches.map(m => m.replace(/[\]"']/g, '').trim());
        }
        
        return [];
      };

      // Definir si la propuesta está bloqueada (ya aceptada)
      const isLocked = ['Aceptada', 'accepted'].includes(proposal.status);
    %>

<main class="min-h-screen bg-gray-50/50" data-proposed-venues='<%- JSON.stringify(proposal.venues || []) %>'>

  <div class="max-w-7xl mx-auto px-4 py-8">

    <!-- Hero Header Section -->
    <% 
      const venueFirstImg = selectedVenue ? parseImages(selectedVenue.images)[0] : null;
      const initialGastroServices = (proposal.services || []).filter(s => s.type === 'gastronomy');
      const initialPendingServices = initialGastroServices.filter(s => s.is_multichoice && (s.selected_option_index === null || s.selected_option_index === undefined || s.selected_option_index === ''));
      const initialSelectedServices = initialGastroServices.filter(s => {
        const idx = Number(s.selected_option_index);
        return s.options && !Number.isNaN(idx) && idx >= 0 && s.options[idx];
      });
      const requiredChoicesCount = 1 + initialGastroServices.filter(s => s.is_multichoice).length;
      const pendingChoicesCount = (selectedVenue ? 0 : 1) + initialPendingServices.length;
      const initialProgressPercent = requiredChoicesCount > 0
        ? Math.max(0, Math.min(100, Math.round(((requiredChoicesCount - pendingChoicesCount) / requiredChoicesCount) * 100)))
        : 100;
    %>
    <section id="inicio" class="mb-8">
      <div class="relative h-[280px] md:h-[360px] w-full overflow-hidden border border-gray-200 shadow-sm hero-print reveal-wow">
        <% if (venueFirstImg) { %>
          <img src="<%= venueFirstImg %>" class="absolute inset-0 w-full h-full object-cover hero-bg-layer" alt="">
        <% } else { %>
          <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-800 to-black hero-bg-layer"></div>
        <% } %>
        <div class="absolute inset-0 bg-gray-900/65 hero-bg-layer"></div>

        <div class="absolute top-5 left-5 md:top-6 md:left-6 z-20 bg-white px-4 py-3 shadow-sm border border-gray-200">
          <img src="/logomice.png" alt="MICE Catering" class="h-8 md:h-10 w-auto object-contain">
        </div>

        <div class="absolute top-5 right-5 md:top-6 md:right-6 z-20 flex flex-wrap items-center justify-end gap-2 print:hidden">
          <button id="btn-download-pdf" class="hidden md:inline-flex items-center gap-2 bg-white/95 hover:bg-white text-gray-800 text-[11px] font-bold px-4 py-2 border border-white/60 shadow-sm transition-colors">
            <i data-lucide="download" class="w-4 h-4"></i>
            <span>Descargar PDF</span>
          </button>
          <% if (!isLocked) { %>
            <button id="btn-modifications" class="inline-flex items-center gap-2 bg-black/65 hover:bg-black text-white text-[11px] font-bold px-4 py-2 border border-white/20 backdrop-blur-sm shadow-sm transition-colors">
              <i data-lucide="pen-square" class="w-4 h-4"></i>
              <span>Solicitar cambios</span>
            </button>
          <% } %>
        </div>

        <% if (proposal.status === 'Aceptada' || proposal.status === 'accepted') { %>
          <div class="absolute left-5 md:left-6 top-24 md:top-28 z-20 flex items-center gap-3 bg-white/95 backdrop-blur-md px-4 py-2 border-l-4 border-[#31713D] shadow-lg">
            <div class="w-8 h-8 bg-[#31713D] text-white flex items-center justify-center">
              <i data-lucide="check" class="w-4 h-4"></i>
            </div>
            <div>
              <p class="text-[10px] font-black text-gray-900 uppercase tracking-widest leading-none">Propuesta Confirmada</p>
              <p class="text-[9px] font-bold text-gray-500 uppercase tracking-[0.2em] mt-1">Estado bloqueado</p>
            </div>
          </div>
        <% } %>

        <div class="absolute inset-x-0 bottom-0 z-10 p-6 md:p-10">
          <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
            <div>
              <h1 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-3 drop-shadow-lg">
                <%= proposal.client_name %>
              </h1>
              <div class="flex flex-wrap items-center gap-4 text-gray-200 text-sm font-medium">
                <span class="flex items-center gap-1.5"><i data-lucide="users" class="w-4 h-4"></i> <%= proposal.pax %> asistentes</span>
                <span class="flex items-center gap-1.5"><i data-lucide="calendar" class="w-4 h-4"></i> <%= proposal.event_date ? dayjs(proposal.event_date).format('D [de] MMMM, YYYY') : 'Fecha por confirmar' %></span>
                <% if (selectedVenue) { %>
                  <span class="flex items-center gap-1.5"><i data-lucide="map-pin" class="w-4 h-4"></i> <%= selectedVenue.name %></span>
                <% } %>
              </div>
            </div>

            <div class="bg-white/95 backdrop-blur-sm border border-white/60 px-5 py-4 shadow-lg min-w-[220px]">
              <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] mb-1">Base actual</p>
              <div id="header-total" class="text-2xl md:text-3xl font-bold text-gray-900 tracking-tight leading-none"><%= formatCurrency(proposal.totals?.total_base_after_discount || 0) %></div>
              <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mt-2">Ref: <%= proposal.custom_ref || 'OF-' + proposal.unique_hash.substring(0,8).toUpperCase() %></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white border border-gray-200 shadow-sm overflow-hidden mb-8 print:hidden scroll-reveal soft-card">
      <div class="px-4 md:px-6 py-4 border-b border-gray-200 bg-gray-50">
        <div class="flex flex-wrap items-center gap-2 text-[11px] font-semibold text-gray-600">
          <a href="#venues-section" class="px-3 py-1.5 bg-white border border-gray-200 hover:text-[#31713D] transition-colors">Espacios</a>
          <a href="#programa" class="px-3 py-1.5 bg-white border border-gray-200 hover:text-[#31713D] transition-colors">Programa</a>
          <a href="#gastronomia-section" class="px-3 py-1.5 bg-white border border-gray-200 hover:text-[#31713D] transition-colors">Gastronomía</a>
          <a href="#total-budget" class="px-3 py-1.5 bg-white border border-gray-200 hover:text-[#31713D] transition-colors">Presupuesto</a>
          <button onclick="toggleSidebar()" class="ml-auto px-3 py-1.5 bg-black text-white hover:bg-gray-800 transition-colors flex items-center gap-2">
            <i data-lucide="list-checks" class="w-4 h-4"></i>
            <span>Mi selección</span>
          </button>
        </div>
      </div>

      <div class="grid lg:grid-cols-[0.95fr_1.05fr] gap-6 p-4 md:p-6">
        <div class="space-y-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] mb-1">Estado de decisión</p>
              <h2 id="choices-status" class="text-lg md:text-xl font-bold text-gray-900 tracking-tight">
                <%= pendingChoicesCount > 0 ? 'ELECCIONES PENDIENTES' : '✓ PROPUESTA COMPLETADA' %>
              </h2>
            </div>
            <span id="progress-percent" class="text-xl font-bold text-[#31713D]"><%= initialProgressPercent %>%</span>
          </div>

          <div class="space-y-2">
            <div class="h-2 w-full bg-gray-200 overflow-hidden">
              <div id="summary-progress-bar" data-initial-progress="<%= initialProgressPercent %>" class="h-2 bg-[#31713D] transition-all duration-500" style="width: 0%;"></div>
            </div>
            <p class="text-[10px] text-gray-500 font-medium">Tu propuesta se desbloquea al completar todas las elecciones obligatorias.</p>
          </div>

          <div id="pending-choices-list" class="flex flex-wrap gap-2">
            <% if (!selectedVenue) { %>
              <a href="#venues-section" class="flex-shrink-0 bg-orange-50 text-orange-600 border border-orange-200 px-3 py-1 text-[9px] font-black uppercase tracking-tighter hover:bg-orange-100 transition-all flex items-center gap-1 group">
                <i data-lucide="alert-circle" class="w-2.5 h-2.5"></i>
                <span>Elegir espacio</span>
              </a>
            <% } %>
            <% initialPendingServices.forEach(service => { %>
              <a href="#service-card-<%= service.id %>" class="flex-shrink-0 bg-orange-50 text-orange-600 border border-orange-200 px-3 py-1 text-[9px] font-black uppercase tracking-tighter hover:bg-orange-100 transition-all flex items-center gap-1 group">
                <i data-lucide="alert-circle" class="w-2.5 h-2.5"></i>
                <span><%= service.title %></span>
              </a>
            <% }) %>
            <% if (selectedVenue && initialPendingServices.length === 0) { %>
              <span class="flex-shrink-0 bg-green-50 text-[#31713D] border border-green-200 px-3 py-1 text-[9px] font-black uppercase tracking-tighter flex items-center gap-1">
                <i data-lucide="check-circle" class="w-2.5 h-2.5"></i>
                <span>Todo revisado</span>
              </span>
            <% } %>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-3">
            <div>
              <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] mb-1">Mi selección</p>
              <h3 class="text-lg font-bold text-gray-900 tracking-tight">Resumen actual</h3>
            </div>
          </div>

          <div id="summary-choices-grid" class="grid sm:grid-cols-2 gap-3">
            <% if (selectedVenue) { %>
              <div class="bg-white border border-gray-200 p-4 shadow-sm">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-gray-50 flex items-center justify-center border border-gray-200">
                    <i data-lucide="map-pin" class="w-4 h-4 text-[#31713D]"></i>
                  </div>
                  <div class="min-w-0">
                    <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Espacio</p>
                    <p class="text-sm font-bold text-gray-900 truncate"><%= selectedVenue.name %></p>
                  </div>
                </div>
              </div>
            <% } %>

            <% initialSelectedServices.forEach(service => { %>
              <% const selectedOpt = service.options[Number(service.selected_option_index)]; %>
              <% if (selectedOpt) { %>
                <div class="bg-white border border-gray-200 p-4 shadow-sm">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-gray-50 flex items-center justify-center border border-gray-200">
                      <i data-lucide="utensils" class="w-4 h-4 text-[#31713D]"></i>
                    </div>
                    <div class="min-w-0">
                      <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1"><%= service.title %></p>
                      <p class="text-sm font-bold text-gray-900 truncate"><%= selectedOpt.name %></p>
                    </div>
                  </div>
                </div>
              <% } %>
            <% }) %>

            <% if (!selectedVenue && initialSelectedServices.length === 0) { %>
              <div class="sm:col-span-2 bg-gray-50 border border-dashed border-gray-300 p-4 text-sm text-gray-500 font-medium">
                Aún no hay selecciones confirmadas. Usa esta guía para avanzar paso a paso.
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content (Single Column) -->
    <div class="space-y-6 pb-8">

        <!-- Venue Selected View -->
        <% const anyVenueSelected = proposal.venues && proposal.venues.some(v => v.is_selected || v.is_selected === 1 || v.is_selected === "1"); %>
        <% if (selectedVenue) { %>
          <% const confirmedVenueImages = parseImages(selectedVenue.images); %>
          <section id="venue-confirmed-view" class="bg-white border border-gray-200 shadow-sm overflow-hidden scroll-reveal soft-card">
            <div class="flex items-center justify-between px-4 md:px-6 py-4 bg-gray-50 border-b border-gray-200">
              <div class="flex items-center gap-3">
                <i data-lucide="building" class="w-5 h-5 text-[#31713D]"></i>
                <h2 class="text-xl font-bold text-gray-900">Ubicación del Evento</h2>
              </div>
              <span class="inline-flex items-center gap-2 bg-green-50 text-[#31713D] border border-green-200 px-3 py-1 text-[10px] font-black uppercase tracking-widest">
                <i data-lucide="check-circle" class="w-3.5 h-3.5"></i>
                Confirmado
              </span>
            </div>

            <div class="grid md:grid-cols-[320px_1fr] gap-0" data-venue='<%- JSON.stringify(selectedVenue).replace(/'/g, "&#39;") %>'>
              <div class="h-56 md:h-full bg-gray-100 border-b md:border-b-0 md:border-r border-gray-200 overflow-hidden">
                <% if (confirmedVenueImages[0]) { %>
                  <img src="<%= confirmedVenueImages[0] %>" class="w-full h-full object-cover" alt="<%= selectedVenue.name %>">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-gray-400 bg-gray-100">
                    <i data-lucide="image-off" class="w-10 h-10"></i>
                  </div>
                <% } %>
              </div>

              <div class="p-6 md:p-8">
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                  <div>
                    <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] mb-2">Espacio seleccionado</p>
                    <h3 class="text-2xl md:text-3xl font-bold text-gray-900 tracking-tight mb-2"><%= selectedVenue.name %></h3>
                    <p class="text-sm text-gray-600 leading-relaxed max-w-2xl"><%= selectedVenue.description || 'Este espacio ha sido priorizado para tu evento y queda reflejado en la propuesta actual.' %></p>
                  </div>
                  <% if (otherVenues && otherVenues.length > 0) { %>
                    <span class="inline-flex items-center gap-2 bg-white border border-gray-200 px-3 py-2 text-[10px] font-bold uppercase tracking-widest text-gray-600">
                      <i data-lucide="refresh-ccw" class="w-3.5 h-3.5"></i>
                      <%= otherVenues.length %> alternativa<%= otherVenues.length > 1 ? 's' : '' %>
                    </span>
                  <% } %>
                </div>

                <div class="flex flex-wrap gap-3 mt-6">
                  <button onclick="openVenueModal(this.closest('[data-venue]').dataset.venue)" class="bg-white hover:bg-gray-50 text-gray-700 text-sm font-semibold px-5 py-2.5 border border-gray-300 transition-colors flex items-center gap-2">
                    <i data-lucide="map" class="w-4 h-4"></i>
                    <span>Ver detalles</span>
                  </button>
                  <% if (!isLocked) { %>
                    <button data-venue-name="<%= selectedVenue.name || '' %>" onclick="window.confirmSelectVenue(null, this.dataset.venueName, true)" class="bg-gray-900 hover:bg-black text-white text-sm font-semibold px-5 py-2.5 transition-colors flex items-center gap-2">
                      <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                      <span>Cambiar espacio</span>
                    </button>
                  <% } %>
                </div>
              </div>
            </div>
          </section>
        <% } %>

        <!-- Venue Selection View -->
        <section id="venues-section" class="bg-white border border-gray-200 shadow-sm overflow-hidden scroll-reveal soft-card <%= anyVenueSelected ? 'hidden' : '' %>" data-any-venue-selected="<%= anyVenueSelected ? 'true' : 'false' %>">
          <div class="flex items-center justify-between px-4 md:px-6 py-4 bg-gray-50 border-b border-gray-200">
            <div class="flex items-center gap-3">
              <i data-lucide="building" class="w-5 h-5 text-[#31713D]"></i>
              <h2 class="text-xl font-bold text-gray-900">Ubicación del Evento</h2>
            </div>
            <div id="venue-controls" class="hidden md:flex items-center gap-2">
              <button onclick="scrollCarousel('venue-carousel', -1)" class="p-1.5 border border-gray-200 text-gray-500 hover:bg-gray-100 transition-colors"><i data-lucide="chevron-left" class="w-4 h-4"></i></button>
              <button onclick="scrollCarousel('venue-carousel', 1)" class="p-1.5 border border-gray-200 text-gray-500 hover:bg-gray-100 transition-colors"><i data-lucide="chevron-right" class="w-4 h-4"></i></button>
            </div>
          </div>

          <div id="venue-selection-view" class="block p-4 md:p-6">
            <div class="bg-orange-50 border border-orange-200 p-3 mb-6 flex items-start gap-3">
              <i data-lucide="alert-circle" class="w-4 h-4 text-orange-600 shrink-0 mt-0.5"></i>
              <div>
                <p class="text-sm font-bold text-orange-700">Acción requerida</p>
                <p class="text-sm text-orange-700/80">Selecciona uno de los espacios propuestos para tu evento.</p>
              </div>
            </div>

            <% if (proposal.venues && proposal.venues.length > 0) { %>
              <div id="venue-carousel" class="flex overflow-x-auto pb-6 gap-5 snap-x snap-mandatory hide-scrollbar scroll-smooth">
                <% proposal.venues.forEach((venue, idx) => { %>
                  <% const venueImages = parseImages(venue.images); %>
                  <div class="min-w-[280px] md:min-w-[320px] snap-center bg-white border border-gray-200 shadow-sm flex flex-col cursor-pointer transition-all hover:-translate-y-1 hover:shadow-md"
                       data-venue='<%- JSON.stringify(venue).replace(/'/g, "&#39;") %>'
                       onclick="openVenueModal(this.dataset.venue)">
                    <div class="h-40 relative border-b border-gray-100 bg-gray-100 overflow-hidden">
                      <% if (venueImages[0]) { %>
                        <img src="<%= venueImages[0] %>" class="w-full h-full object-cover" alt="<%= venue.name %>">
                      <% } else { %>
                        <div class="w-full h-full flex items-center justify-center text-gray-400">
                          <i data-lucide="image-off" class="w-8 h-8"></i>
                        </div>
                      <% } %>
                    </div>

                    <div class="p-5 flex-1 flex flex-col">
                      <h3 class="text-base font-bold text-gray-900 mb-1"><%= venue.name %></h3>
                      <p class="text-sm text-gray-500 mb-4 line-clamp-2 flex-1"><%= venue.description || 'Consulta la ficha detallada del espacio y sus opciones de montaje.' %></p>
                      <div class="flex gap-2 mt-auto">
                        <button onclick="event.stopPropagation(); openVenueModal(this.closest('[data-venue]').dataset.venue)" class="flex-1 bg-white hover:bg-gray-50 text-gray-700 text-sm font-semibold py-2 border border-gray-300 transition-colors flex items-center justify-center gap-1">
                          <i data-lucide="info" class="w-4 h-4"></i>
                          <span>Info</span>
                        </button>
                        <% if (!isLocked) { %>
                          <button data-venue-id="<%= venue.venue_id || venue.id %>" data-venue-name="<%= venue.name || '' %>" onclick="event.stopPropagation(); window.confirmSelectVenue(this.dataset.venueId, this.dataset.venueName)" class="flex-1 bg-[#31713D] hover:bg-black text-white text-sm font-semibold py-2 transition-colors">
                            Elegir
                          </button>
                        <% } else { %>
                          <span class="flex-1 bg-gray-100 text-gray-400 text-sm font-semibold py-2 flex items-center justify-center border border-gray-200">Bloqueado</span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="text-center py-12 bg-gray-50 border-2 border-dashed border-gray-300">
                <i data-lucide="building-2" class="w-12 h-12 text-gray-300 mx-auto mb-3"></i>
                <p class="text-black font-medium">No hay espacios específicos asignados a esta propuesta</p>
              </div>
            <% } %>
          </div>
        </section>

        <script>
          function scrollCarousel(id, direction) {
            const container = document.getElementById(id);
            if (!container) return;
            const scrollAmount = container.clientWidth * 0.8;
            container.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
          }
        </script>

        <!-- Legal Conditions -->
        <% if (proposal.show_legal_conditions && proposal.legal_conditions) { %>
          <div class="bg-gray-50/80 border-l-4 border-[#31713D] p-3 mb-4 shadow-sm scroll-reveal">
            <div class="flex items-start gap-3">
              <i data-lucide="info" class="w-3.5 h-3.5 text-[#31713D] mt-0.5 opacity-70"></i>
              <div class="space-y-0.5">
                <span class="text-[8px] font-black uppercase tracking-[0.15em] text-[#31713D]/80 block mb-0.5">Nota del Comercial</span>
                <p class="text-gray-600 leading-tight whitespace-pre-wrap text-[10px] font-medium italic">
                  "<%= proposal.legal_conditions %>"
                </p>
              </div>
            </div>
          </div>
        <% } %>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- SECCIÓN: OFERTA GASTRONÓMICA (MOSAICO) -->
        <!-- ════════════════════════════════════════════════════════ -->
        <% const gastroServices = (proposal.services || []).filter(s => s.type === 'gastronomy'); %>

        <% if (gastroServices.length > 0) { %>
          <section id="programa" class="card overflow-hidden p-0 mb-0 border border-gray-200 shadow-sm bg-white scroll-reveal soft-card">
            <div class="px-5 md:px-8 py-5 bg-white border-b border-gray-200 flex items-center justify-between gap-4">
              <div class="flex items-center gap-3 min-w-0">
                <span class="w-1.5 h-8 shrink-0 brand-bg"></span>
                <div>
                  <h2 class="text-lg md:text-xl font-black text-gray-900 tracking-tight">Programa y Gastronomía</h2>
                  <p class="text-xs text-gray-500">Todas las elecciones del evento se resuelven aquí, con un flujo premium, limpio y natural.</p>
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class="text-[8px] font-bold text-gray-500 uppercase tracking-widest bg-gray-50 border border-gray-200 px-3 py-1.5">Timeline de elección</span>
              </div>
            </div>

            <div id="timeline-section" class="p-4 md:p-6 bg-gray-50/70">
              <div id="gastronomia-section" class="relative border-l-2 border-gray-200 ml-4 space-y-10 pb-4">
                <% gastroServices.forEach(service => { %>
                  <%
                    const rawSelectedIndex = service.selected_option_index;
                    const hasDecision = !(rawSelectedIndex === null || rawSelectedIndex === undefined || rawSelectedIndex === '');
                    const selectedIndex = hasDecision ? Number(rawSelectedIndex) : null;
                    const isInvalidDecision = hasDecision && Number.isNaN(selectedIndex);
                    const isCancelled = !isInvalidDecision && selectedIndex === -1;
                    const isPending = !hasDecision || isInvalidDecision;
                    const isAdded = !isPending && (service.is_multichoice ? selectedIndex >= 0 : selectedIndex === 0);
                    const isOptional = service.is_optional === true || service.is_optional === 1 || service.is_optional === '1';
                    const showHeaderEconomics = isAdded && !isOptional;
                    const servicePax = service.pax || proposal.pax;
                    const serviceSubtotal = (service.price_per_pax || 0) * servicePax;
                    const optionsSorted = Array.isArray(service.options)
                      ? [...service.options].sort((a, b) => Number(a.id) - Number(b.id))
                      : [];
                  %>

                  <div class="relative pl-6 md:pl-10">
                    <div class="absolute -left-[9px] top-4 w-4 h-4 rounded-full <%= isCancelled ? 'bg-gray-300 ring-4 ring-gray-50' : (isAdded ? 'brand-bg ring-4 ring-green-50' : 'bg-gray-400 ring-4 ring-gray-50') %>"></div>

                    <div id="service-card-<%= service.id %>" class="bg-white overflow-hidden border shadow-sm transition-all hover:shadow-md <%= isCancelled ? 'border-gray-200 opacity-90' : (isAdded ? 'brand-border' : 'border-gray-200') %>">
                      <div class="<%= isCancelled ? 'px-6 py-3' : 'px-6 py-4' %> border-b border-gray-100 flex flex-col md:flex-row md:items-center justify-between gap-5 <%= isCancelled ? 'bg-gray-50' : 'bg-white' %>">
                        <div class="space-y-2">
                          <div class="flex items-center gap-3 flex-wrap">
                            <span class="w-1.5 h-6 rounded-none <%= isCancelled ? 'bg-gray-300' : 'brand-bg' %>"></span>
                            <h3 class="text-2xl font-black <%= isCancelled ? 'text-gray-400 opacity-60' : 'text-gray-900' %> tracking-tight uppercase leading-none m-0"><%= service.title %></h3>

                            <div class="flex items-center gap-1.5 px-3 py-1 bg-white border border-black/10 rounded-none shadow-sm <%= isCancelled ? 'opacity-40 grayscale' : '' %>">
                              <i data-lucide="calendar" class="w-3.5 h-3.5 text-gray-600"></i>
                              <span class="text-[10px] font-black uppercase tracking-widest text-gray-700"><%= dayjs(service.service_date || proposal.event_date).format('DD MMM') %></span>
                            </div>

                            <% if (service.location) { %>
                              <div class="flex items-center gap-1.5 px-3 py-1 bg-white border border-black/10 rounded-none shadow-sm <%= isCancelled ? 'opacity-40 grayscale' : '' %>">
                                <i data-lucide="map-pin" class="w-3.5 h-3.5 text-blue-600"></i>
                                <span class="text-[10px] font-black uppercase tracking-widest text-blue-600"><%= service.location %></span>
                              </div>
                            <% } %>

                            <% if (!isCancelled && !showHeaderEconomics) { %>
                              <div class="px-3 py-1 bg-white border border-gray-200 rounded-none shadow-sm flex items-center gap-2">
                                <span class="text-[9px] font-black uppercase tracking-widest text-gray-600">Subtotal servicio</span>
                                <span class="text-sm font-black tracking-tight leading-none" style="color: var(--brand-primary)"><%= formatCurrency(serviceSubtotal) %></span>
                                <span class="text-[9px] font-black uppercase tracking-widest text-black/40">(<%= servicePax %> pax)</span>
                              </div>
                            <% } %>

                            <% if (service.start_time && !isCancelled) { %>
                              <div class="flex items-center gap-2 px-3 py-0.5 bg-white border border-black rounded-none w-fit">
                                <i data-lucide="clock" class="w-3.5 h-3.5 text-black"></i>
                                <span class="text-[10px] font-black text-black uppercase tracking-widest leading-none"><%= service.start_time.substring(0, 5) %>h</span>
                              </div>
                            <% } %>
                          </div>
                        </div>

                        <div class="flex items-center gap-4 flex-wrap justify-end">
                          <% if (showHeaderEconomics) { %>
                            <div id="service-header-status-<%= service.id %>" class="flex items-center gap-3 flex-wrap">
                              <div class="bg-white px-6 py-3 border border-gray-200 shadow-sm flex items-center gap-6 divide-x divide-gray-100">
                                <div class="text-right">
                                  <span class="text-[9px] font-black text-black uppercase tracking-[0.3em] block mb-0.5 leading-none"><%= servicePax %> ASISTENTES</span>
                                  <span class="text-xl font-black text-gray-900 tracking-tighter leading-none"><%= formatCurrency(service.price_per_pax || 0) %> <small class="text-[10px] text-black font-bold">/u</small></span>
                                </div>
                                <div class="pl-8 text-right">
                                  <span class="text-[9px] font-black text-black uppercase tracking-[0.3em] block mb-0.5 leading-none">SUBTOTAL SERVICIO</span>
                                  <span class="text-2xl font-black tracking-tighter leading-none" style="color: var(--brand-primary)"><%= formatCurrency(serviceSubtotal) %></span>
                                </div>
                              </div>

                              <% if (!isLocked) { %>
                                <button type="button"
                                        onclick="window.updateMilestoneStatus('<%= service.id %>', 'pending')"
                                        class="h-[32px] px-4 border border-gray-300 bg-white text-gray-700 text-[9px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-gray-50 transition-all"
                                        title="Volver a decidir este servicio">
                                  <i data-lucide="rotate-ccw" class="w-3 h-3"></i>
                                  <span>Volver a decidir</span>
                                </button>
                              <% } %>
                            </div>
                          <% } else { %>
                            <div id="service-header-status-<%= service.id %>" class="flex items-center gap-2 flex-wrap">
                              <% if (isCancelled) { %>
                                <% if (!isLocked) { %>
                                  <button type="button"
                                          onclick="window.updateMilestoneStatus('<%= service.id %>', 'pending')"
                                          class="flex items-center gap-4 px-6 py-2.5 bg-white border border-gray-300 rounded-none shadow-sm hover:bg-gray-50 transition-all group">
                                    <i data-lucide="rotate-ccw" class="w-5 h-5 group-hover:rotate-[-45deg] transition-transform" style="color: var(--brand-primary)"></i>
                                    <div class="text-left">
                                      <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest block leading-none mb-1">SERVICIO CANCELADO</span>
                                      <span class="text-xs font-black tracking-tight uppercase" style="color: var(--brand-primary)">RECUPERAR ESTE SERVICIO</span>
                                    </div>
                                  </button>
                                <% } else { %>
                                  <div class="flex items-center gap-4 px-6 py-2.5 bg-gray-50 border border-gray-200 rounded-none shadow-inner opacity-60">
                                    <i data-lucide="x-circle" class="w-5 h-5 text-gray-400"></i>
                                    <div class="text-left">
                                      <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest block leading-none mb-1">CANCELADO</span>
                                      <span class="text-xs font-black text-gray-500 tracking-tight uppercase">No disponible</span>
                                    </div>
                                  </div>
                                <% } %>
                              <% } else if (isOptional) { %>
                                <span class="inline-flex items-center gap-1.5 h-[32px] px-3 border border-gray-200 bg-white text-gray-600 text-[9px] font-black uppercase tracking-widest shadow-sm">
                                  <i data-lucide="sparkles" class="w-3 h-3"></i>
                                  <span>Opcional</span>
                                </span>
                              <% } else if (!isLocked && !service.is_multichoice) { %>
                                <span class="inline-flex items-center gap-1.5 h-[32px] px-3 border border-gray-200 bg-gray-50 text-gray-700 text-[9px] font-black uppercase tracking-widest">
                                  <i data-lucide="alert-circle" class="w-3 h-3"></i>
                                  <span>Pendiente de decisión</span>
                                </span>
                                <button type="button"
                                        onclick="window.updateMilestoneStatus('<%= service.id %>', 'added')"
                                        class="h-[32px] px-5 text-white rounded-none text-[9px] font-black uppercase tracking-widest flex items-center gap-2 transition-all shadow-sm hover:opacity-90"
                                        style="background-color: var(--brand-primary)">
                                  <i data-lucide="plus" class="w-3 h-3"></i>
                                  <span>Añadir ahora</span>
                                </button>
                                <button type="button"
                                        onclick="window.updateMilestoneStatus('<%= service.id %>', 'cancelled')"
                                        class="h-[32px] px-4 bg-white border border-gray-300 text-gray-700 rounded-none text-[9px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-gray-50 transition-all"
                                        title="Cancelar servicio">
                                  <i data-lucide="x" class="w-3 h-3"></i>
                                  <span>No añadir</span>
                                </button>
                              <% } else if (!isOptional) { %>
                                <div class="flex items-center gap-3 px-5 py-3 bg-gray-50 border border-gray-200 rounded-none shadow-inner">
                                  <div class="w-8 h-8 rounded-none bg-gray-200/70 flex items-center justify-center">
                                    <i data-lucide="list-checks" class="w-5 h-5 text-gray-600"></i>
                                  </div>
                                  <div>
                                    <span class="text-[10px] font-black text-gray-700 uppercase tracking-widest block">Elección pendiente</span>
                                    <span class="text-[9px] text-gray-500 font-bold uppercase tracking-tighter">Debes elegir una opción</span>
                                  </div>
                                </div>
                                <button type="button"
                                        onclick="document.getElementById('service-options-container-<%= service.id %>')?.scrollIntoView({ behavior: 'smooth', block: 'center' })"
                                        class="h-[32px] px-4 text-white rounded-none text-[9px] font-black uppercase tracking-widest flex items-center gap-2 transition-all shadow-sm hover:opacity-90"
                                        style="background-color: var(--brand-primary)">
                                  <i data-lucide="mouse-pointer-2" class="w-3 h-3"></i>
                                  <span>Elegir opción</span>
                                </button>
                              <% } %>
                            </div>
                          <% } %>
                        </div>
                      </div>

                      <div id="service-options-container-<%= service.id %>" class="<%= isCancelled ? 'hidden' : 'p-6 md:px-10 md:pt-3 md:pb-8' %>">
                        <% if (optionsSorted.length > 0) { %>
                          <div id="service-options-grid-<%= service.id %>" class="<%= (isOptional && !service.is_multichoice) ? 'space-y-3' : (service.is_multichoice ? 'grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3' : 'space-y-6') %> gap-4">
                            <% optionsSorted.forEach((opt, idx) => { %>
                              <%
                                const isSelected = isAdded && selectedIndex === idx;
                                let menuImg = null;
                                try {
                                  const parsedImages = Array.isArray(opt.images)
                                    ? opt.images
                                    : (typeof opt.images === 'string' ? JSON.parse(opt.images) : []);
                                  if (parsedImages && parsedImages.length > 0) menuImg = parsedImages[0];
                                } catch (e) {}
                                if (!menuImg && opt.items && opt.items.length > 0 && opt.items[0].image_url) {
                                  menuImg = opt.items[0].image_url;
                                }
                                const optPax = service.pax || proposal.pax;
                                const optSubtotal = (opt.price_pax || 0) * optPax;
                              %>

                              <div id="option-card-<%= opt.id %>"
                                   class="menu-option-card transition-all duration-300 p-5 border shadow-sm <%= isOptional && !service.is_multichoice ? (isSelected ? 'brand-border bg-white shadow-md' : 'border-gray-200 bg-white hover:border-gray-300') : (isSelected ? 'border-2 brand-border brand-bg-light shadow-md' : 'border-gray-200 bg-white hover:shadow-md hover:border-gray-300') %> <%= (service.is_multichoice && isAdded && !isSelected) ? 'hidden opacity-0 scale-95' : '' %>"
                                   onclick="openMenuModal(this)"
                                   data-menu='<%- JSON.stringify(opt).replace(/'/g, "&#39;") %>'
                                   data-service-title="<%= service.title %>"
                                   data-service-date="<%= dayjs(service.service_date || proposal.event_date).format('DD/MM/YYYY') %>"
                                   data-service-pax="<%= service.pax || proposal.pax %>"
                                   data-service-price-pax="<%= service.price_per_pax || 0 %>">

                                <% if (isOptional && !service.is_multichoice) { %>
                                  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                                    <div class="min-w-0 flex-1">
                                      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 border border-gray-200 bg-white text-gray-500 text-[8px] font-black uppercase tracking-widest mb-2">
                                        <i data-lucide="sparkles" class="w-3 h-3"></i>
                                        <span>Upgrade opcional</span>
                                      </span>
                                      <h5 class="text-lg md:text-xl font-black text-gray-900 tracking-tight leading-none"><%= opt.name %></h5>
                                      <p class="mt-2 text-sm text-gray-500 leading-relaxed max-w-2xl"><%= opt.description || 'Puedes añadir este servicio de forma voluntaria para enriquecer la experiencia del evento.' %></p>
                                      <div class="mt-3 flex items-center gap-2">
                                        <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">Desde</span>
                                        <span class="text-lg md:text-xl font-black" style="color: var(--brand-primary)"><%= formatCurrency(opt.price_pax || 0) %></span>
                                        <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">/ pax</span>
                                      </div>
                                    </div>

                                    <div id="option-actions-<%= opt.id %>" class="flex items-center justify-between md:justify-end gap-4 md:min-w-[220px]">
                                      <% if (!isLocked) { %>
                                        <div class="text-right">
                                          <p class="text-[10px] font-black uppercase tracking-widest <%= isSelected ? 'brand-text' : 'text-gray-500' %>"><%= isSelected ? 'Añadido' : 'Activar upgrade' %></p>
                                          <p class="text-[11px] text-gray-400">Puedes cambiarlo cuando quieras</p>
                                        </div>
                                        <label class="relative inline-flex items-center cursor-pointer" onclick="event.stopPropagation()">
                                          <input type="checkbox"
                                                 class="sr-only peer"
                                                 data-service-id="<%= service.id %>"
                                                 data-option-id="<%= opt.id %>"
                                                 onchange="window.handleOptionalToggle(this)"
                                                 <%= isSelected ? 'checked' : '' %>>
                                          <div class="w-14 h-8 rounded-full border transition-colors duration-200 <%= isSelected ? 'brand-bg border-transparent' : 'bg-gray-200 border-gray-300' %>"></div>
                                          <div class="pointer-events-none absolute top-1 left-1 h-6 w-6 rounded-full bg-white shadow-sm transition-transform duration-200 <%= isSelected ? 'translate-x-6' : '' %>"></div>
                                        </label>
                                      <% } else { %>
                                        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gray-50 border border-gray-200 rounded-none">
                                          <i data-lucide="sparkles" class="w-3 h-3 text-gray-500"></i>
                                          <span class="text-[9px] font-black uppercase tracking-widest text-gray-500"><%= isSelected ? 'Añadido' : 'Disponible' %></span>
                                        </div>
                                      <% } %>
                                    </div>
                                  </div>
                                <% } else { %>
                                  <div class="flex items-start gap-6">
                                    <div class="flex flex-col gap-2">
                                      <div class="w-24 h-24 md:w-32 md:h-32 flex-shrink-0 overflow-hidden border border-gray-200 shadow-sm relative group bg-gray-50">
                                        <% if (menuImg) { %>
                                          <img src="<%= menuImg %>" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110">
                                        <% } else { %>
                                          <div class="w-full h-full flex items-center justify-center text-gray-200">
                                            <i data-lucide="utensils" class="w-8 h-8 opacity-20"></i>
                                          </div>
                                        <% } %>
                                      </div>
                                      <div class="bg-gray-50 text-gray-700 px-3 py-1 text-center border border-gray-200">
                                        <span class="text-[12px] font-black tracking-tighter leading-none" style="color: var(--brand-primary)"><%= formatCurrency(opt.price_pax || 0) %> <small class="text-[8px] uppercase opacity-60 text-gray-500">/u</small></span>
                                      </div>
                                    </div>

                                    <div class="flex-1 min-w-0">
                                      <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
                                        <div class="flex flex-col">
                                          <h5 class="text-xl md:text-2xl font-black text-gray-900 tracking-tighter leading-none uppercase italic serif truncate"><%= opt.name %></h5>
                                          <div class="mt-1 flex items-center gap-2 px-2 py-0.5 bg-gray-50 border border-gray-200 rounded-none w-fit">
                                            <span class="text-[10px] font-black uppercase tracking-widest text-gray-600">Subtotal menú</span>
                                            <span class="text-base font-black tracking-tight leading-none" style="color: var(--brand-primary)"><%= formatCurrency(optSubtotal) %></span>
                                            <span class="text-[9px] font-black uppercase tracking-widest text-black/40">(<%= optPax %> pax)</span>
                                          </div>
                                        </div>

                                        <div id="option-actions-<%= opt.id %>" class="flex flex-wrap items-center gap-2">
                                          <% if (service.is_multichoice) { %>
                                            <% if (!isLocked) { %>
                                              <button type="button"
                                                      data-service-id="<%= service.id %>"
                                                      data-option-id="<%= opt.id %>"
                                                      data-selected="<%= isSelected %>"
                                                      onclick="event.stopPropagation(); window.handleServiceSelection(this)"
                                                      class="<%= isSelected ? 'bg-white text-gray-700 border border-gray-300' : 'brand-bg text-white border border-transparent' %> h-[34px] px-5 text-[9px] font-black uppercase tracking-widest flex items-center gap-2 transition-all shadow-sm group">
                                                <% if (isSelected) { %>
                                                  <i data-lucide="check" class="w-3 h-3 group-hover:hidden" style="color: var(--brand-primary)"></i>
                                                  <i data-lucide="rotate-ccw" class="w-3 h-3 hidden group-hover:block"></i>
                                                  <span class="group-hover:hidden" style="color: var(--brand-primary)">Seleccionado</span>
                                                  <span class="hidden group-hover:block uppercase">Cambiar</span>
                                                <% } else { %>
                                                  <i data-lucide="mouse-pointer-2" class="w-3 h-3"></i>
                                                  <span>Elegir</span>
                                                <% } %>
                                              </button>
                                            <% } else if (isSelected) { %>
                                              <div class="flex items-center gap-2 px-4 py-2 bg-gray-50 border border-gray-200 rounded-none">
                                                <i data-lucide="check" class="w-3 h-3" style="color: var(--brand-primary)"></i>
                                                <span class="text-[9px] font-black uppercase tracking-widest" style="color: var(--brand-primary)">Confirmado</span>
                                              </div>
                                            <% } %>
                                          <% } else { %>
                                            <% if (isAdded) { %>
                                              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-green-200 bg-green-50 text-[9px] font-black uppercase tracking-widest" style="color: var(--brand-primary)">
                                                <i data-lucide="check" class="w-3 h-3"></i>
                                                <span>Añadido</span>
                                              </span>
                                            <% } else if (isCancelled) { %>
                                              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-gray-300 bg-gray-100 text-gray-600 text-[9px] font-black uppercase tracking-widest">
                                                <i data-lucide="x" class="w-3 h-3"></i>
                                                <span>No añadido</span>
                                              </span>
                                            <% } else if (!isLocked) { %>
                                              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-gray-200 bg-gray-50 text-gray-600 text-[9px] font-black uppercase tracking-widest">
                                                <i data-lucide="arrow-up" class="w-3 h-3"></i>
                                                <span>Decide arriba</span>
                                              </span>
                                            <% } %>
                                          <% } %>
                                        </div>
                                      </div>

                                      <% if (opt.badges && opt.badges.length > 0) { %>
                                        <div class="flex items-center gap-1.5 flex-wrap mt-3">
                                          <% opt.badges.forEach(b => { %>
                                            <span class="bg-gray-100 text-gray-600 px-2 py-0.5 text-[8px] font-black uppercase tracking-widest border border-gray-200"><%= b %></span>
                                          <% }); %>
                                        </div>
                                      <% } %>

                                      <% if (opt.description) { %>
                                        <div class="mt-3 pt-3 border-t border-black/5">
                                          <p class="text-[12px] md:text-[13px] text-black/70 font-medium leading-relaxed italic whitespace-pre-line mb-1"><%= opt.description %></p>
                                        </div>
                                      <% } %>
                                    </div>
                                  </div>
                                <% } %>
                              </div>
                            <% }); %>
                          </div>
                        <% } %>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>
          </section>
        <% } %>

        <!-- Standard Contract Conditions (Institutional) -->
        <div class="card overflow-hidden p-0 bg-white rounded-none mb-0 border-none shadow-none !mt-0 print:break-before-page <%= !proposal.show_general_conditions ? 'hidden print:hidden' : '' %>">
          <div class="brand-bg px-8 py-5 flex items-center justify-between cursor-pointer group border-b border-white/5" onclick="document.getElementById('institutional-conditions').classList.toggle('hidden')">
            <h2 class="font-black uppercase tracking-widest text-[11px] flex items-center">
              <span class="bg-white px-4 py-2 flex items-center gap-2 shadow-sm">
                <i data-lucide="shield-check" class="text-[#31713D] w-4 h-4"></i> 
                <span class="text-black">Condiciones Generales de Contratación</span>
              </span>
            </h2>
            <i data-lucide="chevron-down" class="w-4 h-4 text-white/40 group-hover:text-white transition-colors"></i>
          </div>
          
          <div id="institutional-conditions" class="p-8 md:p-12 space-y-10 hidden">
            <% 
               const genConds = proposal.general_conditions || '';
               const sections = genConds.split(/\n(?=[A-ZÁÉÍÓÚ\s]+:)/).filter(s => s.trim());
               const middle = Math.ceil(sections.length / 2);
               const leftCol = sections.slice(0, middle);
               const rightCol = sections.slice(middle);
            %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20">
              
              <!-- Left Column -->
              <div class="space-y-10">
                <% leftCol.forEach(section => { 
                   const lines = section.split('\n').filter(l => l.trim());
                   const title = lines[0].replace(':', '').trim();
                   const items = lines.slice(1);
                %>
                  <section>
                    <h3 class="text-[#31713D] font-black uppercase tracking-widest text-[12px] mb-6 flex items-center gap-3">
                      <span class="w-2 h-6 bg-[#31713D]"></span> <%= title %>
                    </h3>
                    <ul class="space-y-3 text-[11px] text-gray-600 leading-relaxed">
                      <% items.forEach(item => { 
                         const isBullet = item.startsWith('-');
                         const text = isBullet ? item.substring(1).trim() : item.trim();
                      %>
                        <li class="flex gap-3">
                          <i data-lucide="<%= isBullet ? 'check' : 'info' %>" class="w-3.5 h-3.5 text-[#31713D] flex-shrink-0 mt-0.5"></i>
                          <span><%- text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') %></span>
                        </li>
                      <% }); %>
                    </ul>
                  </section>
                <% }); %>
              </div>

              <!-- Right Column -->
              <div class="space-y-10">
                <% rightCol.forEach(section => { 
                   const lines = section.split('\n').filter(l => l.trim());
                   const title = lines[0].replace(':', '').trim();
                   const items = lines.slice(1);
                %>
                  <section>
                    <h3 class="text-[#31713D] font-black uppercase tracking-widest text-[12px] mb-6 flex items-center gap-3">
                      <span class="w-2 h-6 bg-[#31713D]"></span> <%= title %>
                    </h3>
                    <ul class="space-y-3 text-[11px] text-gray-600 leading-relaxed">
                      <% items.forEach(item => { 
                         const isBullet = item.startsWith('-');
                         const text = isBullet ? item.substring(1).trim() : item.trim();
                      %>
                        <li class="flex gap-3">
                          <i data-lucide="<%= isBullet ? 'check' : 'info' %>" class="w-3.5 h-3.5 text-[#31713D] flex-shrink-0 mt-0.5"></i>
                          <span><%- text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') %></span>
                        </li>
                      <% }); %>
                    </ul>
                  </section>
                <% }); %>
              </div>
            </div>
          </div>
        </div>

        <!-- SECCIÓN MANIFIESTO: SOSTENIBILIDAD (Homogeneizada) -->
        <div class="card overflow-hidden p-0 bg-white rounded-none mb-0 border-none shadow-none !mt-0 print:hidden transition-shadow">
          <div onclick="toggleSustainability()" class="brand-bg px-8 py-5 flex items-center justify-between cursor-pointer group border-b border-white/5">
                          <div class="flex items-center gap-6">
              <h2 class="font-black uppercase tracking-widest text-[11px] flex items-center">
                <span class="bg-white px-4 py-2 flex items-center gap-2 shadow-sm">
                  <i data-lucide="leaf" class="text-[#31713D] w-4 h-4"></i> 
                  <span class="text-black">Propuesta Sostenible</span>
                </span>
              </h2>
            </div>
            
            <div class="flex items-center gap-6">
              <i data-lucide="chevron-down" id="sustainability-chevron" class="w-4 h-4 text-white/40 group-hover:text-white transition-colors"></i>
            </div>
          </div>

          <div id="manifiesto-content" class="hidden print:block bg-white">
            
            <!-- Selector de Secciones (Visible solo al desplegar) -->
            <div class="border-b border-black flex flex-nowrap overflow-x-auto bg-gray-50/50 p-2 gap-2 print:hidden scrollbar-hide">
              <% sustainabilityConfig.forEach((sec, idx) => { %>
                <button data-slide-id="<%= sec.id %>" 
                  class="whitespace-nowrap flex-1 px-4 py-3 rounded-none text-[9px] font-black uppercase tracking-widest <%= idx === 0 ? 'bg-white shadow-sm text-gray-900 border-black' : 'text-black hover:text-gray-900 border-transparent' %> border transition-all" 
                  id="btn-slide-<%= sec.id %>">
                  <i data-lucide="<%= sec.icon %>" class="w-3 h-3 mb-1 mx-auto hidden md:block opacity-40"></i>
                  <span class="block"><%= sec.titulo %></span>
                </button>
              <% }); %>
            </div>

            <% sustainabilityConfig.forEach((sec, idx) => { %>
              <div id="slide-<%= sec.id %>" class="slide-container <%= idx === 0 ? 'print:block' : 'hidden print:block' %> <%= sec.bgColor %> <%= sec.textColor %>">
                <div class="flex flex-col lg:flex-row min-h-[500px]">
                  
                  <!-- Contenido Texto -->
                  <div class="w-full lg:w-1/2 p-12 md:p-16 flex flex-col justify-center <%= (idx % 2) === 0 ? 'order-first lg:order-last' : '' %>">
                    <div class="space-y-8 text-left">
                      <span class="text-[12px] font-black uppercase tracking-[0.4em] border-l-4 pl-6 block" data-sec-color="<%= sec.color %>">
                        Pilar <%= sec.pilar %>
                      </span>
                      <h3 class="text-5xl font-black tracking-tighter leading-none m-0">
                        <%= sec.titulo.split(' ').slice(0, -1).join(' ') %> <br>
                        <span data-sec-color="<%= sec.color %>" class="<%= (idx % 2) !== 0 ? 'italic serif' : '' %>">
                          <%= sec.destaque %>
                        </span>
                      </h3>
                      <p class="<%= sec.textColor === 'text-white' ? 'text-white/60' : 'text-black' %> text-lg font-light leading-relaxed max-w-sm">
                        <%= sec.descripcion %>
                      </p>

                      <!-- Subsecciones Dinámicas -->
                      <div class="space-y-6 pt-4">
                        <% if (sec.features) { %>
                          <% sec.features.forEach(f => { %>
                            <div class="flex items-start gap-4">
                              <div class="w-10 h-10 rounded-none flex items-center justify-center flex-shrink-0" data-sec-bg="<%= sec.color + '20' %>">
                                <i data-lucide="<%= f.icon %>" class="w-5 h-5" data-sec-color="<%= sec.color %>"></i>
                              </div>
                              <div>
                                <p class="text-sm font-black uppercase tracking-widest"><%= f.titulo %></p>
                                <p class="text-xs opacity-60 font-light max-w-sm"><%= f.desc %></p>
                              </div>
                            </div>
                          <% }); %>
                        <% } %>

                        <% if (sec.cards) { %>
                          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <% sec.cards.forEach(c => { %>
                              <div class="p-5 rounded-none border <%= c.full ? 'md:col-span-2' : '' %>" data-sec-bg="<%= sec.color + '10' %>" data-sec-border="<%= sec.color + '20' %>">
                                <i data-lucide="<%= c.icon %>" class="w-6 h-6 mb-2" data-sec-color="<%= sec.color %>"></i>
                                <p class="text-[10px] font-black uppercase tracking-widest"><%= c.titulo %></p>
                                <p class="text-[9px] opacity-70 font-bold"><%= c.desc %></p>
                              </div>
                            <% }); %>
                          </div>
                        <% } %>

                        <% if (sec.tags) { %>
                          <div class="grid grid-cols-2 gap-6 pt-2 grayscale opacity-60">
                            <% sec.tags.forEach(t => { %>
                              <div class="flex flex-col gap-2 <%= t.image ? '' : 'border-l border-black pl-4' %>">
                                <% if (t.image) { %>
                                  <img src="<%= t.image %>" class="h-8 w-auto object-contain mr-auto">
                                <% } else { %>
                                  <i data-lucide="<%= t.icon %>" class="w-6 h-6" data-sec-color="<%= sec.color %>"></i>
                                <% } %>
                                <p class="text-[8px] font-bold text-black uppercase tracking-widest"><%= t.label %></p>
                              </div>
                            <% }); %>
                          </div>
                        <% } %>

                        <% if (sec.items) { %>
                          <div class="space-y-4">
                            <% sec.items.forEach(it => { %>
                              <div class="flex items-center gap-4">
                                <i data-lucide="<%= it.icon %>" class="w-5 h-5" data-sec-color="<%= sec.color %>"></i>
                                <span class="text-[11px] font-black uppercase tracking-widest"><%= it.label %></span>
                              </div>
                            <% }); %>
                          </div>
                        <% } %>

                        <% if (sec.certificates) { %>
                          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <% sec.certificates.forEach(cert => { %>
                              <div class="bg-white p-6 border border-black shadow-sm flex flex-col items-center text-center">
                                <% if (cert.img) { %>
                                  <img src="<%= cert.img %>" class="h-12 mb-4 grayscale">
                                <% } else { %>
                                  <div class="w-12 h-12 bg-gray-50 flex items-center justify-center rounded-none mb-4">
                                    <i data-lucide="<%= cert.icon %>" class="w-6 h-6 text-black"></i>
                                  </div>
                                <% } %>
                                <p class="text-[10px] font-black uppercase tracking-widest text-gray-900"><%= cert.name %></p>
                                <p class="text-[8px] text-black mt-1"><%= cert.desc %></p>
                              </div>
                            <% }); %>
                          </div>
                        <% } %>
                      </div>

                    </div>
                  </div>

                  <!-- Imagen Lateral -->
                  <div class="w-full lg:w-1/2 relative bg-gray-50 min-h-[400px]">
                    <img src="<%= sec.imagen %>" class="absolute inset-0 w-full h-full object-cover <%= sec.textColor === 'text-white' ? 'opacity-60' : '' %>" alt="<%= sec.titulo %>">
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>

        <!-- Propuesta Económica Title (Style unified with conditions) -->
        <div class="card overflow-hidden p-0 rounded-none border-none mb-0 !mt-0 print:hidden shadow-none">
          <div class="brand-bg px-8 py-5 flex items-center justify-between cursor-pointer group" onclick="toggleBudgetBreakdown()">
            <h2 class="font-black uppercase tracking-widest text-[11px] flex items-center">
              <span class="bg-white px-4 py-2 flex items-center gap-2 shadow-sm">
                <i data-lucide="calculator" class="text-[#31713D] w-4 h-4"></i> 
                <span class="text-black">Propuesta Económica</span>
              </span>
              <span class="hidden sm:inline text-[9px] font-bold text-white/50 ml-4 tracking-normal uppercase">(Clic para ver detalle)</span>
            </h2>
            
            <div class="flex items-center gap-6">
              <div class="hidden md:flex items-center gap-4">
                <span class="text-[9px] font-black text-[#4ade80] uppercase tracking-widest animate-pulse">Ver desglose detallado</span>
                <div class="h-4 w-px bg-white/10"></div>
                <i data-lucide="check" class="text-[#4ade80] w-3.5 h-3.5"></i>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-[8px] font-bold text-white/40 uppercase tracking-widest md:hidden">Ver detalle</span>
                <i data-lucide="chevron-down" id="breakdown-chevron" class="w-4 h-4 text-white/40 group-hover:text-white transition-all duration-300"></i>
              </div>
            </div>
          </div>
        </div>

        <!-- Budget Total Card (At bottom) -->
        <div id="total-budget" class="card overflow-hidden shadow-sm border border-gray-200 bg-white p-0 print:border-none print:shadow-none !mt-0 mb-4 scroll-reveal soft-card">
          <% 
            const pendingGastro = (proposal.services || []).filter(s => 
              s.type === 'gastronomy' && s.is_multichoice && (s.selected_option_index === null || s.selected_option_index === undefined)
            );
            const hasAddedMilestone = (proposal.services || []).some(s => {
              const idx = s.selected_option_index;
              if (idx === null || idx === undefined || idx === -1) return false;
              return s.is_multichoice ? idx >= 0 : idx === 0;
            });
          %>
          
          <div class="p-6 md:p-10">
            

            <div class="flex flex-col lg:flex-row items-stretch lg:items-center justify-between gap-10">
              
              <!-- Financial breakdown: Only Base Imponible (remove Inversión Final card) -->
              <div onclick="toggleBudgetBreakdown()" class="flex-1 grid grid-cols-12 gap-8 items-stretch cursor-pointer group">
                <!-- 1. BASE IMPONIBLE (MASTER CARD - EQUAL WIDTH) -->
                <div class="col-span-12 p-6 md:p-8 bg-white border border-gray-200 shadow-sm group-hover:shadow-md transition-all flex flex-col justify-between min-h-[240px] relative">
                  <div class="flex flex-col sm:flex-row justify-between items-start gap-4">
                    <span class="text-[12px] font-black text-black uppercase tracking-[0.4em] flex items-center gap-2">
                        <span class="w-2 h-6 bg-black"></span> Base Imponible
                    </span>
                    <% if (proposal.totals?.total_discount > 0) { %>
                        <div class="flex flex-col items-end gap-2">
                            <% if (proposal.totals?.discounts && proposal.totals.discounts.length > 0) { %>
                                <% proposal.totals.discounts.forEach((disc, idx) => { %>
                                    <div class="bg-green-50 text-[#31713D] px-4 py-2 flex items-center gap-3 shadow-sm border border-green-200">
                                        <i data-lucide="gift" class="w-4 h-4"></i>
                                        <div class="flex flex-col">
                                            <span class="text-[10px] font-black uppercase tracking-widest">Descuento aplicado</span>
                                            <span class="text-lg font-black">-<%= disc.amount.toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €</span>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="bg-green-50 text-[#31713D] px-4 py-2 flex items-center gap-3 shadow-sm border border-green-200">
                                    <i data-lucide="gift" class="w-4 h-4"></i>
                                    <div class="flex flex-col">
                                        <span class="text-[10px] font-black uppercase tracking-widest">Descuento aplicado</span>
                                        <span class="text-lg font-black">-<%= (proposal.totals?.total_discount || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €</span>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                  </div>
                  <div class="flex flex-col mt-4 gap-4">
                    <% if (proposal.totals?.total_discount > 0) { %>
                      <div class="flex items-center gap-3 mb-1">
                         <span class="text-xl md:text-2xl lg:text-3xl font-black text-black line-through uppercase tracking-tighter opacity-20 truncate">
                            <%= (proposal.totals?.total_base || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €
                          </span>
                      </div>
                    <% } %>
                    <div class="flex items-baseline flex-wrap gap-x-2">
                      <span id="final-base-after-discount" class="text-4xl md:text-6xl lg:text-7xl font-black text-[#31713D] tracking-tighter leading-none break-all">
                        <%= Math.floor(proposal.totals?.total_base_after_discount || 0).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".") %><span class="text-xl md:text-2xl text-[#31713D]">,<%= ((proposal.totals?.total_base_after_discount % 1).toFixed(2).split('.')[1]) || '00' %></span><span class="ml-1 text-2xl md:text-3xl">€</span>
                      </span>
                      <span class="ml-4 text-[10px] font-black uppercase tracking-widest text-gray-400">Pulsa para desglose</span>
                    </div>
                    <div class="flex flex-col md:flex-row gap-4 mt-4">
                      <div class="flex-1 flex flex-col items-start">
                        <span class="text-[10px] font-black uppercase tracking-widest text-black">Impuestos (IVA)</span>
                        <span id="final-vat" class="text-2xl font-black text-amber-600"><%= (proposal.totals?.total_vat || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €</span>
                      </div>
                      <div class="flex-1 flex flex-col items-start">
                        <span class="text-[10px] font-black uppercase tracking-widest text-black">Total + IVA</span>
                        <span id="final-total" class="text-2xl font-black text-green-700"><%= (proposal.totals?.total_final || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Action Zone -->
              <div id="economics-action-zone" class="lg:w-[260px] shrink-0 flex flex-col gap-3 print:hidden">
                <% if (proposal.status === 'Aceptada') { %>
                  <div class="bg-green-50 px-6 py-5 border border-green-200 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-none bg-[#31713D] text-white flex items-center justify-center shrink-0 shadow-sm">
                      <i data-lucide="check" class="w-5 h-5"></i>
                    </div>
                    <div>
                      <span class="text-[10px] font-black uppercase tracking-widest text-[#31713D]">Confirmada</span>
                      <p class="text-[9px] text-black font-bold">Reserva Activa</p>
                    </div>
                  </div>
                  
                  <!-- Chat always available -->
                  <button onclick="toggleChat(event)" class="w-full bg-white hover:bg-green-50 text-gray-800 border border-gray-300 py-3 font-black uppercase tracking-widest text-[9px] flex items-center justify-center gap-2 transition-all">
                    <i data-lucide="message-square" class="w-3.5 h-3.5 text-[#31713D]"></i> Chat con Comercial
                  </button>
                <% } else if (proposal.status === 'cancelled') { %>
                  <div class="bg-gray-100 px-6 py-5 rounded-none border border-black flex items-center gap-4 grayscale">
                     <span class="text-[10px] font-black uppercase tracking-widest text-black">Propuesta Desestimada</span>
                  </div>
                <% } else { %>
                    <!-- Main Action -->
                    <% if (pendingGastro.length > 0) { %>
                      <a href="#gastronomia-section" class="bg-amber-600 text-white px-6 py-4 rounded-none font-black uppercase tracking-widest text-[10px] shadow-lg hover:bg-amber-700 transition-all flex items-center justify-center gap-3">
                        <span>Seleccione su Propuesta Gastronómica</span>
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                      </a>
                    <% } else if (!hasAddedMilestone) { %>
                      <div class="bg-gray-100 text-black/60 px-6 py-5 rounded-none font-black uppercase tracking-widest text-[10px] border border-gray-200 flex items-center justify-center gap-3">
                        <i data-lucide="alert-triangle" class="w-4 h-4"></i>
                        <span>Debe añadir al menos un hito para aceptar</span>
                      </div>
                    <% } else { %>
                      <button id="btn-accept" 
                              class="text-white px-6 py-5 rounded-none font-black uppercase tracking-widest text-[11px] shadow-lg transition-all transform hover:-translate-y-0.5 active:scale-[0.98] flex items-center justify-center gap-3 group"
                              style="background-color: var(--brand-primary)">
                        <i data-lucide="shield-check" class="w-5 h-5"></i>
                        <span>Confirmar Propuesta Comercial</span>
                      </button>
                    <% } %>

                    <!-- Secondary Actions -->
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                      <button onclick="toggleChat(event)" class="bg-white hover:bg-green-50 text-gray-800 border border-gray-300 py-3 font-black uppercase tracking-widest text-[9px] flex items-center justify-center gap-2 transition-all">
                        <i data-lucide="message-square" class="w-3.5 h-3.5 text-[#31713D]"></i> Chat
                      </button>

                      <button type="button" onclick="document.getElementById('modal-modifications').classList.remove('hidden')" class="bg-white hover:bg-amber-50 text-gray-800 border border-gray-300 py-3 font-black uppercase tracking-widest text-[9px] flex items-center justify-center gap-2 transition-all">
                        <i data-lucide="pen-square" class="w-3.5 h-3.5 text-amber-600"></i> Cambios
                      </button>

                      <button id="btn-reject" type="button" onclick="document.getElementById('modal-reject').classList.remove('hidden')" class="bg-white hover:bg-red-50 text-gray-800 border border-gray-300 py-3 font-black uppercase tracking-widest text-[9px] flex items-center justify-center gap-2 transition-all">
                        <i data-lucide="x" class="w-3.5 h-3.5 text-red-600"></i> Rechazar
                      </button>
                    </div>
                <% } %>
              </div>
            </div>

            <!-- Detailed Breakdown Table (Hidden by default) -->
            <div id="budget-breakdown-details" class="hidden mt-10 pt-10 border-t border-black overflow-hidden w-full">
              <h4 class="text-[11px] font-black text-black uppercase tracking-[0.3em] mb-8 flex items-center gap-3">
                 <span class="w-1.5 h-4 bg-black"></span> Desglose económico detallado
              </h4>
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-gray-100 text-gray-700">
                      <th class="py-4 text-[9px] font-black uppercase tracking-[0.2em] px-6 border-r border-gray-200">Concepto / Servicio</th>
                      <th class="py-4 text-[9px] font-black uppercase tracking-[0.2em] text-right px-6 border-r border-gray-200">Base Imponible</th>
                      <th class="py-4 text-[9px] font-black uppercase tracking-[0.2em] text-right px-6 border-r border-gray-200">IVA %</th>
                      <th class="py-4 text-[9px] font-black uppercase tracking-[0.2em] text-right px-6 border-r border-gray-200">Cuota IVA</th>
                      <th class="py-4 text-[9px] font-black uppercase tracking-[0.2em] text-right px-6">Precio Total</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-black/10">
                    <% 
                      const totalBase = proposal.totals?.total_base || 1;
                      const totalBaseAfter = proposal.totals?.total_base_after_discount || 0;
                      const globalDiscountRatio = totalBaseAfter / totalBase;
                    %>
                    <% (proposal.totals?.breakdown || []).forEach(item => { %>
                      <tr class="hover:bg-green-50 transition-colors group/row">
                        <td class="py-6 px-6 border-r border-black/5">
                          <span class="text-[11px] font-black text-black uppercase tracking-wider block group-hover/row:text-[#31713D]">
                            <%= item.name.includes(' - ') ? item.name.split(' - ')[1] : item.name %><% if (item.price_model !== 'fixed') { %>, para <%= item.pax %> asistentes<% } %>
                          </span>
                          <span class="text-[8px] font-bold text-black/40 uppercase tracking-widest mt-1 block">
                            <%= item.name.includes(' - ') ? item.name.split(' - ')[0] : 'Servicio' %>
                          </span>
                        </td>
                        <td class="py-6 px-6 text-right text-sm font-black text-black font-mono border-r border-black/5 whitespace-nowrap">
                          <%= (item.subtotal || 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> €
                        </td>
                        <td class="py-6 px-6 text-right text-[11px] font-black text-black/70 italic border-r border-black/5"><%= item.vat_rate %>%</td>
                        <td class="py-6 px-6 text-right text-sm font-black text-black font-mono border-r border-black/5 whitespace-nowrap">
                          <% const itemVat = item.subtotal * (item.vat_rate / 100) * globalDiscountRatio; %>
                          <%= (itemVat || 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> €
                        </td>
                        <td class="py-6 px-6 text-right text-sm font-black text-black font-mono whitespace-nowrap">
                          <%= (item.subtotal + itemVat).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> €
                        </td>
                      </tr>
                    <% }) %>

                    <% if (proposal.totals?.discounts && proposal.totals.discounts.length > 0) { %>
                      <% proposal.totals.discounts.forEach(discount => { %>
                        <tr class="bg-[#F2F8F3] group/disc">
                          <td class="py-6 px-6 border-r border-black/5">
                            <div class="flex items-center gap-2">
                                <i data-lucide="gift" class="w-4 h-4 text-[#31713D]"></i>
                                <div>
                                    <span class="text-[11px] font-black text-[#31713D] uppercase tracking-wider block"><%= discount.name %></span>
                                    <span class="text-[8px] font-black text-black/40 uppercase italic">Descuento Comercial</span>
                                </div>
                            </div>
                          </td>
                          <td class="py-6 px-6 text-right text-sm font-black text-[#31713D] font-mono border-r border-black/5 whitespace-nowrap">
                            -<%= (discount.amount || 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> €
                          </td>
                          <td class="py-6 px-6 text-right text-[11px] font-black text-black/30 border-r border-black/5"></td>
                          <td class="py-6 px-6 text-right text-sm font-black text-black/30 font-mono border-r border-black/5"></td>
                          <td class="py-6 px-6 text-right text-sm font-black text-[#31713D] font-mono whitespace-nowrap">
                            -<%= (discount.amount || 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> €
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                  <tfoot class="bg-gray-50 text-gray-900 border-t border-gray-200">
                    <tr>
                      <td class="py-6 px-6 text-[10px] font-black uppercase tracking-widest">INVERSIÓN FINAL</td>
                      <td class="py-6 px-6 text-right font-mono text-sm text-[#31713D]">
                         <%= (proposal.totals?.total_base_after_discount || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €
                      </td>
                      <td class="py-6 px-6"></td>
                      <td class="py-6 px-6 text-right font-mono text-sm">
                         <%= (proposal.totals?.total_vat || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €
                      </td>
                      <td class="py-6 px-6 text-right font-mono text-xl font-black text-[#31713D]">
                         <%= (proposal.totals?.total_final || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
          </div>
          
          <div class="bg-gray-50 px-10 py-4 flex justify-between items-center text-black">
            <span class="text-[8px] font-bold uppercase tracking-[0.2em]">MICE CATERING © 2026 // Propuesta Comercial</span>
            <span class="text-[10px] font-black uppercase tracking-widest">Base Imponible tras descuento: <%= (proposal.totals?.total_base_after_discount || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ".") %> €</span>
            <% if (!isLocked) { %>
              <button onclick="window.print()" class="text-black hover:text-gray-600 flex items-center gap-2 text-[9px] font-black uppercase tracking-widest transition-all">
                <i data-lucide="printer" class="w-3.5 h-3.5"></i> Guardar PDF
              </button>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Print Only Footer Decorator -->
  <div class="hidden print:block fixed bottom-0 left-0 w-full py-8 px-12 border-t border-black bg-white">
    <div class="flex justify-between items-center">
      <div class="flex items-center gap-4">
        <img src="/logomice.png" alt="MICE Catering" class="h-8 w-auto">
        <div class="h-8 w-px bg-gray-200"></div>
        <div class="text-[8px] font-black text-black uppercase tracking-[0.2em] leading-tight">
          Catering Corporativo de Alto Nivel<br>
          micecatering.com
        </div>
      </div>
      <div class="text-right">
        <p class="text-[8px] font-black text-gray-900 uppercase tracking-widest mb-1">Tu Asesor: <%= proposal.commercial_name %></p>
        <p class="text-[7px] text-black italic">Esta propuesta tiene carácter informativo y está sujeta a disponibilidad.</p>
      </div>
    </div>
  </div>
</main>

<!-- Modal: Solicitar Modificaciones -->
<div id="modal-modifications" class="fixed inset-0 bg-black/80 hidden flex items-center justify-center z-[100] p-4 backdrop-blur-md">
  <div class="bg-white rounded-none shadow-2xl max-w-lg w-full transform transition-all overflow-hidden border border-white/10">
    <div class="px-8 py-8 relative flex flex-col items-center text-center overflow-hidden">
      <!-- Fondo decorativo con branding -->
      <div class="absolute top-0 left-0 w-full h-24 opacity-10" style="background-color: var(--brand-primary)"></div>
      
      <% if (proposal.logo_url) { %>
        <img src="<%= proposal.logo_url %>" alt="<%= proposal.client_name %>" class="h-8 w-auto mb-6 relative z-10 scale-110 object-contain">
      <% } %>

      <h2 class="text-2xl font-black uppercase tracking-tighter text-gray-900 mb-2 relative z-10">
        ¿Qué cambios necesitas?
      </h2>
      <p class="text-black text-sm mb-6 max-w-[80%]">Nuestro asesor <%= proposal.commercial_name %> recibirá tu solicitud inmediatamente.</p>

      <div class="w-full space-y-4 relative z-10">
        <textarea id="modifications-text" 
          placeholder="Ej: Aumentar 10 invitados, cambiar la hora de inicio a las 20:30, añadir opciones sin gluten..."
          rows="5"
          class="w-full bg-gray-50 border-2 border-black rounded-none p-6 text-sm font-medium focus:border-gray-300 focus:ring-0 transition-all resize-none placeholder:text-gray-300"></textarea>
      </div>

      <div class="grid grid-cols-2 gap-3 w-full mt-8 relative z-10">
        <button id="btn-cancel-modifications" onclick="document.getElementById('modal-modifications').classList.add('hidden')" class="py-4 text-black font-bold uppercase tracking-widest text-[10px] hover:text-gray-600 transition-colors">
          Cancelar
        </button>
        <button id="btn-send-modifications" 
                class="text-white py-4 font-black uppercase tracking-widest text-[11px] rounded-none shadow-xl hover:brightness-110 active:scale-95 transition-all"
                style="background-color: var(--brand-primary)">
          Enviar Mensaje
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal: Rechazar Propuesta -->
<div id="modal-reject" class="fixed inset-0 bg-black/80 hidden flex items-center justify-center z-[100] p-4 backdrop-blur-md">
  <div class="bg-white rounded-none shadow-2xl max-w-md w-full transform transition-all overflow-hidden border border-white/10">
    <div class="p-8 text-center">
      <div class="w-16 h-16 bg-red-50 text-red-600 rounded-none flex items-center justify-center mx-auto mb-6 border border-red-100">
        <i data-lucide="alert-triangle" class="w-8 h-8"></i>
      </div>
      
      <h3 class="text-2xl font-black text-gray-900 mb-2 uppercase tracking-tighter">¿Rechazar Propuesta?</h3>
      <p class="text-black text-sm mb-8 leading-relaxed">
        Lamentamos que la propuesta no encaje. Si nos indicas el motivo, podremos ajustar futuras ofertas a tus necesidades.
      </p>

      <div class="space-y-4 mb-8">
        <textarea id="reject-reason" 
          placeholder="Cuéntanos el motivo (opcional)..."
          rows="3"
          class="w-full bg-gray-50 border border-black rounded-none p-4 text-xs font-medium focus:border-red-500 focus:ring-0 transition-all resize-none"></textarea>
      </div>

      <div class="flex flex-col gap-2">
        <button id="btn-confirm-reject" class="w-full py-4 bg-red-600 text-white font-black uppercase tracking-widest rounded-none hover:bg-red-700 transition-all shadow-lg shadow-red-200">
          CONFIRMAR RECHAZO
        </button>
        <button id="btn-cancel-reject" onclick="document.getElementById('modal-reject').classList.add('hidden')" class="w-full py-3 text-black font-bold text-[10px] uppercase tracking-widest hover:text-gray-600 transition-colors">
          VOLVER ATRÁS
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal: Confirmar Selección de Venue -->
<div id="modal-confirm-venue" class="fixed inset-0 bg-black/70 hidden flex items-center justify-center z-[100] p-4 backdrop-blur-md">
  <div class="bg-white rounded-none shadow-2xl max-w-sm w-full transform transition-all overflow-hidden border border-white/10">
    <div class="p-8 text-center flex flex-col items-center">
      <div id="confirm-venue-media" class="relative w-20 h-20 mb-6 border border-black/10 shadow-inner bg-gray-50 overflow-hidden flex items-center justify-center">
        <img id="confirm-venue-preview" src="" alt="Preview venue" class="w-full h-full object-cover hidden">
        <div id="confirm-venue-overlay" class="absolute hidden inset-x-0 bottom-0 bg-black/70 px-2 py-1 text-left">
          <span id="confirm-venue-overlay-name" class="block text-[8px] font-black uppercase tracking-wider text-white truncate"></span>
        </div>
        <div id="confirm-venue-icon" class="w-full h-full flex items-center justify-center" style="background-color: var(--brand-primary); opacity: 0.1">
          <i data-lucide="map-pin" class="w-10 h-10" style="color: var(--brand-primary)"></i>
        </div>
      </div>
      
      <h3 class="text-2xl font-black text-gray-900 mb-2 uppercase tracking-tighter">¿Confirmar Espacio?</h3>
