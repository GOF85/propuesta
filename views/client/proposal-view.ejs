<!-- Script Toggle Chat -->
<script>
  window.toggleChat = function(event) {
    if (event) event.stopPropagation();
    const chatWindow = document.getElementById('chat-window');
    if (!chatWindow) return;
    
    const isHidden = chatWindow.classList.contains('hidden');
    
    if (isHidden) {
      chatWindow.classList.remove('hidden');
      chatWindow.classList.add('flex');
      // Limpiar badges al abrir
      if (window.showChatBadges) window.showChatBadges(false);
      // Foco al input tras un pequeño delay para que la transición (si hubiera) respete
      setTimeout(() => {
        const input = document.getElementById('chat-input');
        if(input) input.focus();
        
        // Scroll al fondo al abrir
        const chatMessages = document.getElementById('chat-messages');
        if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;
      }, 100);
    } else {
      chatWindow.classList.add('hidden');
      chatWindow.classList.remove('flex');
    }
  };

  // Cierre por click fuera o ESC para Chat Cliente
  document.addEventListener('click', (e) => {
    const chatWindow = document.getElementById('chat-window');
    const chatWidget = document.getElementById('chat-widget');
    if (!chatWindow || chatWindow.classList.contains('hidden')) return;
    
    // Si el click es fuera del widget completo y no es el botón toggle
    if (!chatWidget.contains(e.target)) {
      window.toggleChat();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const chatWindow = document.getElementById('chat-window');
      if (chatWindow && !chatWindow.classList.contains('hidden')) {
        window.toggleChat();
      }
    }
  });

  // Funciones para Manifiesto Sostenible
  function toggleSustainability() {
    console.log('Toggle Sustainability triggered');
    const content = document.getElementById('manifiesto-content');
    if (!content) return;

    const isHidden = content.classList.contains('hidden');
    if (isHidden) {
      content.classList.remove('hidden');
    } else {
      content.classList.add('hidden');
    }

    const chevron = document.getElementById('sustainability-chevron');
    if (chevron) {
      chevron.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
      chevron.style.transition = 'transform 0.3s ease';
    }

    // Asegurar iconos al abrir
    if (isHidden && typeof lucide !== 'undefined') {
      setTimeout(() => lucide.createIcons(), 10);
    }
  }

  // Hacerlas globales
  window.toggleSustainability = toggleSustainability;

  window.showSlide = function(id) {
    console.log('Showing slide:', id);
    // Esconder todos los containers
    const slides = document.querySelectorAll('.slide-container');
    slides.forEach(el => el.classList.add('hidden'));
    
    // Mostrar el seleccionado
    const target = document.getElementById('slide-' + id);
    if(target) target.classList.remove('hidden');

    // Actualizar botones
    document.querySelectorAll('[id^="btn-slide-"]').forEach(btn => {
      btn.classList.remove('bg-white', 'shadow-sm', 'text-gray-900', 'border-black');
      btn.classList.add('text-black', 'border-transparent');
    });

    const activeBtn = document.getElementById('btn-slide-' + id);
    if(activeBtn) {
      activeBtn.classList.remove('text-black', 'border-transparent');
      activeBtn.classList.add('bg-white', 'shadow-sm', 'text-gray-900', 'border-black');
    }
    
    // Refresh icons if content was hidden
    if (typeof lucide !== 'undefined') lucide.createIcons();
  };

  // Auto-open chat if hash is #chat
  window.addEventListener('DOMContentLoaded', () => {
    if (window.location.hash === '#chat') {
      setTimeout(() => {
        const chatWindow = document.getElementById('chat-window');
        if (chatWindow && chatWindow.classList.contains('hidden')) {
          toggleChat();
        }
      }, 800);
    }
  });

  // Toggle para desglose económico
  window.toggleBudgetBreakdown = function() {
    const details = document.getElementById('budget-breakdown-details');
    const chevron = document.getElementById('breakdown-chevron');
    if (!details || !chevron) return;
    
    if (details.classList.contains('hidden')) {
      details.classList.remove('hidden');
      chevron.classList.add('rotate-180');
      // Scroll suave al desglose
      details.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } else {
      details.classList.add('hidden');
      chevron.classList.remove('rotate-180');
    }
  };
</script>

