  <!-- Zoom Slider Container -->
  <div class="relative w-full max-w-6xl aspect-[16/9] md:h-[80vh]">
    <div class="w-full h-full overflow-hidden">
      <div id="zoom-carousel" class="flex h-full w-full transition-transform duration-500 ease-out">
        <!-- Inyectado por JS -->
      </div>
    </div>

    <!-- Navigation -->
    <button id="zoom-prev" onclick="changeZoomImage(-1)" class="absolute left-0 md:-left-16 top-1/2 -translate-y-1/2 text-white/30 hover:text-white transition-colors p-4 z-10">
      <i data-lucide="chevron-left" class="w-12 h-12"></i>
    </button>
    <button id="zoom-next" onclick="changeZoomImage(1)" class="absolute right-0 md:-right-16 top-1/2 -translate-y-1/2 text-white/30 hover:text-white transition-colors p-4 z-10">
      <i data-lucide="chevron-right" class="w-12 h-12"></i>
    </button>

    <!-- Indicator -->
    <div class="absolute -bottom-12 left-1/2 -translate-x-1/2 flex gap-3 items-center">
      <span id="zoom-current" class="text-white font-black text-xl">1</span>
      <span class="text-white/20 text-sm">/</span>
      <span id="zoom-total" class="text-white/40 font-bold text-lg">0</span>
    </div>
  </div>
</div>

<!-- Professional Styles -->
<style>
  @media print {
    @page {
      margin: 1.5cm;
      size: A4;
    }
    
    body {
      background: white !important;
      font-size: 12pt;
    }

    .print\:hidden {
      display: none !important;
    }

    /* Force background colors */
    * {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }

    /* Container adjustments */
    .max-w-7xl, .max-w-6xl {
      max-width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    main {
      padding: 0 !important;
      background: white !important;
    }

    /* Hide elements not needed in PDF */
    nav, footer, .fixed, .modal, button, a[href^="#"], .cursor-pointer {
      display: none !important;
    }

    /* Card adjustments for print */
    .card {
      box-shadow: none !important;
      border: 1px solid #eee !important;
      break-inside: avoid;
      margin-bottom: 0.1rem !important;
      padding-top: 0.5rem !important;
      padding-bottom: 0.5rem !important;
    }

    .card > div {
      padding-top: 0.25rem !important;
      padding-bottom: 0.25rem !important;
    }

    /* Hero section print refinement */
    .hero-print {
      min-height: 380px !important;
      break-after: avoid;
      background-color: #111827 !important;
    }

    .hero-print img {
      opacity: 1 !important;
    }

    /* Print Titles */
    .card-header {
      background-color: #f3f4f6 !important;
