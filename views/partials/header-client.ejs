<!-- Header Navigation for Client View -->
<%
  const selectedVenueHeader = proposal.venues ? proposal.venues.find(v => v.is_selected) : null;
  let headImg = null;
  if (selectedVenueHeader && selectedVenueHeader.images) {
    try {
      const imgs = typeof selectedVenueHeader.images === 'string' ? JSON.parse(selectedVenueHeader.images) : selectedVenueHeader.images;
      if (Array.isArray(imgs) && imgs.length > 0) headImg = imgs[0];
    } catch (e) {
      const clean = String(selectedVenueHeader.images).replace(/[\[\]"']/g, '').trim();
      headImg = clean.split(',')[0];
    }
  }
%>

<div class="sticky top-0 z-50 print:hidden">
  <header class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between gap-4">
      <div class="flex items-center gap-4 min-w-0">
        <div class="w-8 h-8 bg-black flex items-center justify-center text-white font-black text-sm">M</div>
        <div class="min-w-0">
          <span class="block font-semibold text-gray-900 tracking-tight">MICE CATERING</span>
          <span class="block text-[10px] font-black text-gray-400 uppercase tracking-[0.25em] leading-none">Corporate proposals</span>
        </div>
      </div>

      <div class="flex items-center gap-2 md:gap-4">
        <% if (proposal.logo_url) { %>
          <div class="hidden md:flex items-center justify-center bg-white border border-gray-200 px-4 py-2 shadow-sm">
            <img src="<%= proposal.logo_url %>" alt="<%= proposal.client_name %>" class="h-7 w-auto object-contain grayscale opacity-80">
          </div>
        <% } %>

        <button onclick="openCommercialModal()" class="hidden md:inline-flex items-center gap-2 text-[11px] font-bold text-gray-700 hover:text-[#31713D] border border-gray-200 px-3 py-2 bg-white transition-colors">
          <i data-lucide="user-round" class="w-4 h-4"></i>
          <span><%= proposal.commercial_name || 'Tu asesor' %></span>
        </button>

        <button onclick="toggleChat(event)" class="group inline-flex items-center gap-2 bg-black hover:bg-gray-800 text-white px-3 py-2 transition-colors relative shadow-sm">
          <div class="relative">
            <i data-lucide="message-circle" class="w-4 h-4 text-white"></i>
            <span id="chat-badge-header" class="absolute -top-1 -right-1 w-2.5 h-2.5 bg-red-500 border-2 border-white hidden"></span>
          </div>
          <span class="text-[11px] font-black uppercase tracking-widest hidden sm:block">Chat</span>
        </button>
      </div>
    </div>
  </header>

  <div class="bg-gray-50/90 backdrop-blur border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-2 flex items-center justify-between gap-4">
      <nav class="flex items-center gap-2 overflow-x-auto hide-scrollbar text-sm font-medium text-gray-600">
        <a href="#inicio" class="px-3 py-1.5 whitespace-nowrap hover:text-[#31713D] transition-colors">Inicio</a>
        <a href="#venues-section" class="px-3 py-1.5 whitespace-nowrap hover:text-[#31713D] transition-colors">Espacios</a>
        <a href="#timeline-section" class="px-3 py-1.5 whitespace-nowrap hover:text-[#31713D] transition-colors">Programa</a>
        <a href="#gastronomia-section" class="px-3 py-1.5 whitespace-nowrap hover:text-[#31713D] transition-colors">Gastronomía</a>
        <a href="#total-budget" class="px-3 py-1.5 whitespace-nowrap hover:text-[#31713D] transition-colors">Presupuesto</a>
      </nav>

      <button onclick="toggleSidebar()" class="shrink-0 inline-flex items-center gap-2 bg-white border border-gray-200 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-gray-900 hover:border-black transition-colors shadow-sm">
        <i data-lucide="list-checks" class="w-4 h-4 text-[#31713D]"></i>
        <span>Mi selección</span>
        <span id="sidebar-count" class="bg-[#31713D] text-white min-w-[20px] h-5 px-1.5 flex items-center justify-center text-[9px] font-black">0</span>
        <span id="header-pending-badge" onclick="window.scrollToFirstPendingChoice(event)" title="Ir al primer pendiente" class="hidden inline-flex bg-amber-400 text-black min-w-[20px] h-5 px-1.5 items-center justify-center text-[9px] font-black uppercase cursor-pointer hover:bg-amber-300 transition-colors">0</span>
      </button>
    </div>
  </div>

  <div class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-3 grid grid-cols-1 md:grid-cols-[1.35fr_0.8fr_0.8fr_1fr] gap-3 items-stretch">
      <div class="bg-[#31713D] text-white px-4 py-3 flex items-center gap-3 cursor-pointer hover:brightness-110 transition-all group min-w-0"
           <% if (selectedVenueHeader) { %>
             data-venue='<%- JSON.stringify(selectedVenueHeader).replace(/'/g, "&#39;") %>'
             onclick="openVenueModal(this.dataset.venue)"
           <% } %>>
        <div id="header-venue-icon" class="w-10 h-10 flex-shrink-0 bg-white/10 flex items-center justify-center border border-white/20 overflow-hidden">
          <% if (headImg) { %>
            <img src="<%= headImg %>" class="w-full h-full object-cover" alt="Venue">
          <% } else { %>
            <i data-lucide="map-pin" class="w-5 h-5 text-white/60"></i>
          <% } %>
        </div>
        <div class="min-w-0">
          <p class="text-[9px] font-black text-white/60 uppercase tracking-[0.3em] leading-none mb-1">Ubicación</p>
          <p id="header-venue-name" class="text-base font-black tracking-tighter uppercase truncate leading-none">
            <%= selectedVenueHeader ? selectedVenueHeader.name : 'Múltiples opciones' %>
          </p>
        </div>
      </div>

      <div class="bg-white border border-gray-200 px-4 py-3 flex items-center gap-3 min-w-0">
        <div class="w-10 h-10 flex-shrink-0 bg-gray-50 flex items-center justify-center text-[#31713D] border border-gray-100">
          <i data-lucide="users" class="w-4.5 h-4.5"></i>
        </div>
        <div>
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-[0.3em] leading-none mb-1">Asistentes</p>
          <p class="text-xl font-black text-gray-900 tracking-tighter leading-none"><%= proposal.pax %> <small class="text-[9px] text-gray-300 ml-1">PAX</small></p>
        </div>
      </div>

      <div class="bg-white border border-gray-200 px-4 py-3 flex items-center gap-3 min-w-0">
        <div class="w-10 h-10 flex-shrink-0 bg-gray-50 flex items-center justify-center text-[#31713D] border border-gray-100">
          <i data-lucide="calendar" class="w-4.5 h-4.5"></i>
        </div>
        <div>
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-[0.3em] leading-none mb-1">Fecha</p>
          <p class="text-xl font-black text-gray-900 tracking-tighter uppercase leading-none">
            <%= proposal.event_date ? dayjs(proposal.event_date).format('DD MMM YY').toUpperCase() : '--' %>
          </p>
        </div>
      </div>

      <button onclick="toggleSidebar()" class="bg-black text-white px-4 py-3 flex items-center justify-between gap-3 group transition-all hover:bg-gray-800 min-w-0">
        <div class="flex items-center gap-3 text-left min-w-0">
          <div class="w-10 h-10 flex-shrink-0 bg-white/10 flex items-center justify-center text-green-400 border border-white/10">
            <i data-lucide="clipboard-list" class="w-4.5 h-4.5"></i>
          </div>
          <div class="min-w-0">
            <div class="text-[10px] font-black text-white uppercase tracking-[0.2em] leading-none mb-1">Resumen</div>
            <p id="header-pending-text" onclick="window.scrollToFirstPendingChoice(event)" class="text-[9px] font-bold text-amber-300/90 uppercase tracking-wider truncate cursor-pointer hover:text-amber-200 transition-colors" title="Ir al primer pendiente">Pendientes: 0</p>
          </div>
        </div>
        <i data-lucide="chevron-right" class="w-4 h-4 text-white/40 group-hover:translate-x-1 transition-transform"></i>
      </button>
    </div>

    <div id="progress-container" class="border-t border-gray-100">
      <div id="quick-decision-rail" class="max-w-7xl mx-auto px-4 md:px-8 py-2 bg-gray-50/60 flex items-center gap-2 overflow-x-auto hide-scrollbar">
        <span class="text-[8px] font-black uppercase tracking-widest text-gray-500">Siguiente paso:</span>
        <span class="text-[8px] font-bold uppercase tracking-wider text-gray-400">Calculando…</span>
      </div>
    </div>
  </div>
</div>

<div id="modal-commercial-contact"
     class="fixed inset-0 bg-black/60 hidden flex items-center justify-center z-[100] p-4 backdrop-blur-md"
     onclick="if(event.target === this) closeCommercialModal()">
  <div class="bg-white shadow-2xl max-w-sm w-full overflow-hidden border border-gray-200" onclick="event.stopPropagation()">
    <div class="h-28 relative flex items-center justify-center overflow-hidden" style="background-color: var(--brand-primary)">
      <div class="absolute inset-0 opacity-15 bg-white"></div>
      <p class="relative text-white/60 text-[10px] font-black uppercase tracking-[0.3em]">Personal Advisor</p>
    </div>

    <div class="px-8 pb-8 -mt-12 text-center relative z-10">
      <div class="w-24 h-24 border-4 border-white shadow-[0_10px_30px_rgba(0,0,0,0.15)] mx-auto overflow-hidden bg-white mb-4">
        <% if (proposal.commercial_avatar) { %>
          <img src="<%= proposal.commercial_avatar %>" alt="<%= proposal.commercial_name %>" class="w-full h-full object-cover">
        <% } else { %>
          <div class="w-full h-full flex items-center justify-center text-gray-300">
            <i data-lucide="user" class="w-12 h-12"></i>
          </div>
        <% } %>
      </div>

      <h3 class="text-2xl font-black text-gray-900 leading-none tracking-tighter mb-1"><%= proposal.commercial_name %></h3>
      <p class="text-[10px] font-black uppercase tracking-widest mb-6 opacity-80" style="color: var(--brand-primary)">
        Asesor MICE Catering · <%= proposal.client_name %>
      </p>

      <div class="space-y-3">
        <% if (proposal.commercial_email) { %>
          <a href="mailto:<%= proposal.commercial_email %>" class="flex items-center justify-between px-5 py-4 bg-gray-50 hover:bg-white hover:shadow-lg transition-all group border border-gray-100">
            <div class="flex items-center gap-3 min-w-0">
              <i data-lucide="mail" class="w-5 h-5 text-blue-500 group-hover:scale-110 transition-transform"></i>
              <span class="text-sm font-bold text-gray-700 font-mono tracking-tighter truncate"><%= proposal.commercial_email %></span>
            </div>
            <i data-lucide="external-link" class="w-3.5 h-3.5 text-gray-300"></i>
          </a>
        <% } %>

        <% if (proposal.commercial_phone) { %>
          <a href="tel:<%= proposal.commercial_phone %>" class="flex items-center justify-between px-5 py-4 bg-gray-50 hover:bg-white hover:shadow-lg transition-all group border border-gray-100">
            <div class="flex items-center gap-3">
              <i data-lucide="phone" class="w-5 h-5 group-hover:scale-110 transition-transform" style="color: var(--brand-primary)"></i>
              <span class="text-sm font-bold text-gray-700"><%= proposal.commercial_phone %></span>
            </div>
            <i data-lucide="chevron-right" class="w-4 h-4 text-gray-300"></i>
          </a>
        <% } %>

        <button onclick="closeCommercialModal(); toggleChat(event);"
                class="flex items-center justify-center gap-3 w-full py-4 text-white transition-all shadow-lg hover:shadow-xl active:scale-[0.98] group mt-2"
                style="background-color: var(--brand-primary)">
          <i data-lucide="message-circle" class="w-5 h-5 group-hover:rotate-12 transition-transform"></i>
          <span class="text-sm font-black uppercase tracking-widest">Chat en vivo</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function openCommercialModal() {
    document.getElementById('modal-commercial-contact').classList.remove('hidden');
    if (window.lucide) lucide.createIcons();
  }

  function closeCommercialModal() {
    document.getElementById('modal-commercial-contact').classList.add('hidden');
  }
</script>
