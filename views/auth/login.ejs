<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title %> - MICE Catering</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body { background: #F3F4F6; }
    .brand-green { color: #31713D; }
    .brand-bg-green { background-color: #31713D; }
    .brand-border-green { border-color: #31713D; }
    .brand-btn-green {
      background-color: #31713D;
      color: #fff;
    }
    .brand-btn-green:hover {
      background-color: #24552E;
      color: #fff;
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-md">
    <!-- Card -->
    <div class="bg-white rounded-lg shadow-xl p-8">
      <!-- Header -->
      <div class="text-center mb-8">
        <img src="/logomice.png" alt="MICE Catering" class="mx-auto h-20 mb-3" style="max-height:80px;object-fit:contain;" />
        <h1 class="text-3xl font-bold brand-green">MICE Catering</h1>
        <p class="text-gray-700 mt-2">Propuestas Comerciales</p>
      </div>

      <!-- Error Messages -->
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
          <%= error_msg[0] %>
        </div>
      <% } %>

      <!-- Success Messages -->
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="mb-4 p-4 bg-green-100 border border-green-400 text-[#31713D] rounded">
          <%= success_msg[0] %>
        </div>
      <% } %>

      <!-- Login Form -->
      <form method="POST" action="/login" class="space-y-6">
        <!-- Email Field -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Correo Electrónico
          </label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="tu@email.com"
            value="test@example.com"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#31713D] focus:border-transparent outline-none"
          />
          <small class="text-gray-500 mt-1 block">Demo: test@example.com</small>
        </div>

        <!-- Password Field -->
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
            Contraseña
          </label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="••••••••"
            value="password123"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#31713D] focus:border-transparent outline-none"
          />
          <small class="text-gray-500 mt-1 block">Demo: password123</small>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full brand-btn-green font-semibold py-2 px-4 rounded-lg hover:shadow-lg transition-shadow duration-200"
        >
          Iniciar Sesión
        </button>
      </form>

      <!-- Footer -->
      <div class="mt-8 pt-6 border-t border-gray-200 text-center text-sm text-gray-600">
        <p>Servicio exclusivo para agentes registrados</p>
        <img src="/logomice.png" alt="Logo MICE Catering" class="mx-auto mt-4 h-8 opacity-60" style="max-height:32px;object-fit:contain;" />
      </div>
    </div>
  </div>
</body>
</html>
