<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - MICE CATERING</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/lucide@latest"></script>
    <link rel="stylesheet" href="/css/professional.css">
    <style>
        @media print {
            nav, footer, button, .print-hidden { display: none !important; }
        }
    </style>
</head>
<body class="bg-gray-50">

<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-4 py-2">
    
    <!-- Flash Messages -->
    <%- include('../partials/flash-messages') %>

    <!-- Header con Título y Botón Nueva Propuesta -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-4 gap-3">
        <div>
            <h1 class="text-xl font-black text-gray-900 tracking-tighter">Mis Propuestas</h1>
        </div>
        <div class="flex items-center gap-2 w-full md:w-auto">
            <a href="/proposal/new" class="flex-1 md:flex-none bg-[#31713D] hover:bg-black text-white px-4 py-1.5 rounded-xl shadow-lg shadow-green-900/10 font-black uppercase tracking-widest text-[9px] flex items-center justify-center gap-2 transition-all transform active:scale-95 print-hidden">
                <i data-lucide="plus" class="w-3.5 h-3.5"></i> Crear Propuesta
            </a>
        </div>
    </div>

    <!-- Barra de Control (Filtros + Search) -->
    <div class="bg-white p-1 rounded-2xl border border-gray-200 mb-3 flex flex-col lg:flex-row gap-2 shadow-sm items-center">
        <!-- Filtros Estilo Apple -->
        <div class="flex p-0.5 bg-gray-100/80 rounded-xl gap-0.5 overflow-x-auto no-scrollbar shrink-0">
            <a href="?status=all" class="px-3 py-1 rounded-lg text-[8px] font-black uppercase tracking-[0.1em] transition-all <%= currentFilter === 'all' ? 'bg-white text-gray-900 shadow-sm ring-1 ring-black/5' : 'text-gray-400 hover:text-gray-600' %>">
                Todas
            </a>
            <a href="?status=unread" class="px-3 py-1 rounded-lg text-[8px] font-black uppercase tracking-[0.1em] transition-all flex items-center gap-1.5 <%= currentFilter === 'unread' ? 'bg-white text-orange-600 shadow-sm ring-1 ring-black/5' : 'text-gray-400 hover:text-gray-600' %>">
                Pendientes
                <% if (locals.totalUnreadChats > 0) { %>
                    <span class="bg-red-500 text-white w-3 h-3 flex items-center justify-center rounded-full text-[7px] font-black translate-y-[-1px]"><%= totalUnreadChats %></span>
                <% } %>
            </a>
            <a href="?status=Pipe" class="px-3 py-1 rounded-lg text-[8px] font-black uppercase tracking-[0.1em] transition-all <%= currentFilter === 'Pipe' ? 'bg-white text-gray-900 shadow-sm ring-1 ring-black/5' : 'text-gray-400 hover:text-gray-600' %>">
                Pipe
            </a>
            <a href="?status=Aceptada" class="px-3 py-1 rounded-lg text-[8px] font-black uppercase tracking-[0.1em] transition-all <%= currentFilter === 'Aceptada' ? 'bg-white text-gray-900 shadow-sm ring-1 ring-black/5' : 'text-gray-400 hover:text-gray-600' %>">
                Aceptada
            </a>
            <a href="?status=Anulada" class="px-3 py-1 rounded-lg text-[8px] font-black uppercase tracking-[0.1em] transition-all <%= currentFilter === 'Anulada' ? 'bg-white text-gray-900 shadow-sm ring-1 ring-black/5' : 'text-gray-400 hover:text-gray-600' %>">
                Anulada
            </a>
            <a href="?status=archived" class="px-3 py-1 rounded-lg text-[8px] font-black uppercase tracking-[0.1em] transition-all flex items-center gap-1.5 <%= currentFilter === 'archived' ? 'bg-white text-gray-900 shadow-sm ring-1 ring-black/5' : 'text-gray-400 hover:text-gray-600' %>">
                <i data-lucide="archive" class="w-3 h-3"></i>
                Archivada
            </a>
        </div>

        <!-- Search Input High-Fidelity -->
        <div class="flex-1 relative group w-full">
            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-[#31713D] transition-colors pointer-events-none z-10">
                <i data-lucide="search" class="w-4 h-4" style="width: 14px; height: 14px;"></i>
            </div>
            <input 
                type="text" 
                id="searchInput"
                placeholder="Buscar por cliente, venue o OV (# REF)..." 
                value="<%= searchTerm %>"
                class="w-full bg-white border border-gray-200 rounded-xl h-10 pl-11 pr-10 text-[11px] font-medium focus:ring-4 focus:ring-green-100 focus:border-[#31713D] transition-all placeholder:text-gray-400 shadow-sm"
                style="padding-left: 42px !important;"
            >
            <div id="searchLoading" class="absolute right-4 top-1/2 -translate-y-1/2 hidden transition-opacity">
                <i data-lucide="loader-2" class="w-4 h-4 animate-spin text-gray-400"></i>
            </div>
        </div>
    </div>

    <!-- Tabla de Propuestas -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <% if (proposals.length === 0) { %>
            <!-- Empty State -->
            <div class="p-12 text-center">
                <div class="flex justify-center mb-4">
                    <i data-lucide="clipboard-list" class="w-12 h-12 text-gray-400"></i>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">No hay propuestas</h3>
                <p class="text-gray-500 mb-6">
                    <% if (searchTerm) { %>
                        No se encontraron resultados para "<%= searchTerm %>"
                    <% } else if (currentFilter !== 'all') { %>
                        No tienes propuestas con estado <%= statusLabel(currentFilter) %>
                    <% } else { %>
                        Crea tu primera propuesta para empezar
                    <% } %>
                </p>
                <a href="/proposal/new" class="inline-block bg-[#31713D] hover:bg-[#24552E] text-white px-6 py-2 rounded-lg font-medium">
                    + Crear Propuesta
                </a>
            </div>
        <% } else { %>
            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 border-b border-gray-200 text-gray-500">
                        <tr>
                            <th class="px-1 py-2 text-[9px] font-bold uppercase tracking-wider text-center w-8">Notif</th>
                            <% if (user.role === 'admin') { %>
                                <th class="px-1 py-2 text-[9px] font-bold uppercase tracking-wider text-center w-10">Comercial</th>
                            <% } %>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider">Oportunidad (OV)</th>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider">Cliente / Evento</th>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider">Fecha Evento</th>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider">Venue</th>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider text-right">Importe Est.</th>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider text-center">Estado</th>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider text-center">Visto</th>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider text-center" title="Bloquear edición al cliente">Revisión</th>
                            <th class="px-3 py-2 text-[9px] font-bold uppercase tracking-wider text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% proposals.forEach(p => { %>
                        <tr class="hover:bg-gray-50 transition-colors group cursor-pointer border-l-4 <%= p.unread_messages > 0 ? 'bg-orange-50/30 border-l-orange-500 shadow-[inset_0_0_10px_rgba(255,165,0,0.05)]' : 'border-l-transparent' %> <%= (p.status === 'Anulada' || p.status === 'cancelled') ? 'bg-red-50/40' : '' %>"
                            onclick="window.location.href='/proposal/<%= p.id %>/edit'">
                            <!-- Notif -->
                            <td class="px-1 py-1 text-center">
                                <% if (p.unread_messages > 0) { %>
                                    <div class="flex items-center justify-center">
                                        <span class="flex items-center justify-center bg-orange-500 text-white text-[9px] font-bold w-4 h-4 rounded-full shadow-sm animate-pulse" title="<%= p.unread_messages %> mensajes nuevos">
                                            <%= p.unread_messages %>
                                        </span>
                                    </div>
                                <% } else { %>
                                    <div class="flex items-center justify-center text-gray-200 group-hover:text-gray-300">
                                        <i data-lucide="message-square" class="w-3 h-3 opacity-20"></i>
                                    </div>
                                <% } %>
                            </td>
                            <!-- Comercial (Admin only) -->
                            <% if (user.role === 'admin') { %>
                            <td class="px-1 py-1 text-center">
                                <div class="flex items-center justify-center relative group" onclick="event.stopPropagation()">
                                    <img 
                                        src="<%= p.commercial_avatar || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(p.commercial_name || 'Comercial') + '&background=0D8ABC&color=fff' %>" 
                                        class="w-6 h-6 rounded-full border border-gray-200 shadow-xs object-cover cursor-help transition-transform group-hover:scale-110"
                                        alt="<%= p.commercial_name %>"
                                    >
                                    
                                    <!-- Tooltip simplificado -->
                                    <div class="absolute bottom-full mb-2 px-2 py-1 bg-gray-900 text-white text-[10px] font-bold rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-[100] whitespace-nowrap pointer-events-none">
                                        <%= p.commercial_name %>
                                    </div>
                                </div>
                            </td>
                            <% } %>
                            <!-- OV -->
                            <td class="px-3 py-1.5">
                                <div class="flex flex-col">
                                    <span class="text-[11px] font-black text-[#31713D] uppercase tracking-tighter leading-tight">
                                        <%= p.custom_ref || 'Sin Ref.' %>
                                    </span>
                                </div>
                            </td>
                            <!-- Cliente / Evento -->
                            <td class="px-3 py-1.5">
                                <div class="flex flex-col">
                                    <div class="font-black text-[11px] <%= (p.status === 'Anulada' || p.status === 'cancelled') ? 'text-red-800 line-through opacity-50' : 'text-gray-900' %> tracking-tight leading-tight">
                                        <%= p.client_name %>
                                    </div>
                                    <div class="text-[10px] font-bold <%= p.client_category ? 'text-[#31713D] uppercase tracking-tighter' : 'text-gray-400' %> truncate max-w-[150px]">
                                        <%= p.client_category || 'Evento Corporativo' %>
                                    </div>
                                </div>
                            </td>

                            <!-- Fecha Evento -->
                            <td class="px-3 py-1.5">
                                <div class="flex flex-col">
                                    <span class="text-[11px] font-black text-gray-700 tracking-tighter leading-none"><%= p.formattedDate %></span>
                                    <span class="text-[8px] font-bold text-gray-400 mt-0.5 uppercase tracking-widest leading-none"><%= p.pax %> Pax</span>
                                </div>
                            </td>

                            <!-- Venue -->
                            <td class="px-3 py-1.5">
                                <% if (p.venue_names) { %>
                                    <div class="flex items-center gap-1.5 group/venue">
                                        <div class="w-4 h-4 rounded-full <%= p.has_selected_venue ? 'bg-green-50 text-green-600 border-green-200' : 'bg-gray-50 text-gray-400 border-gray-200' %> flex items-center justify-center border opacity-70 shrink-0 shadow-xs">
                                            <i data-lucide="<%= p.has_selected_venue ? 'check-circle-2' : 'map-pin' %>" class="w-2.5 h-2.5"></i>
                                        </div>
                                        <span class="text-[10px] font-black text-gray-600 uppercase tracking-tight truncate max-w-[100px] leading-none"><%= p.venue_names %></span>
                                    </div>
                                <% } else { %>
                                    <span class="px-1.5 py-0.5 bg-yellow-50 text-yellow-600 rounded text-[8px] font-black border border-yellow-100 uppercase tracking-tighter">
                                        Pendiente
                                    </span>
                                <% } %>
                            </td>

                            <!-- Importe Estimado -->
                            <td class="px-3 py-1.5 text-right">
                                <div class="flex flex-col items-end">
                                    <span class="font-black text-xs <%= (p.status === 'Anulada' || p.status === 'cancelled') ? 'text-red-800 opacity-50' : 'text-gray-900' %> tracking-tighter">
                                        <%= p.total > 0 ? p.formattedTotal : '--' %>
                                    </span>
                                </div>
                            </td>

                            <!-- Estado -->
                            <td class="px-3 py-1.5 text-center">
                                <span class="inline-flex px-2 py-0.5 rounded-full text-[8px] font-black uppercase tracking-widest border shadow-xs
                                    <% if (p.statusColor === 'yellow') { %>
                                        bg-gray-50 text-gray-500 border-gray-200
                                    <% } else if (p.statusColor === 'green') { %>
                                        bg-green-50 text-[#31713D] border-green-200
                                    <% } else if (p.statusColor === 'red') { %>
                                        bg-red-50 text-red-600 border-red-200
                                    <% } else if (p.statusColor === 'blue') { %>
                                        bg-blue-50 text-blue-600 border-blue-200
                                    <% } else if (p.statusColor === 'gray') { %>
                                        bg-gray-100 text-gray-400 border-gray-200
                                    <% } else { %>
                                        bg-amber-50 text-amber-600 border-amber-200
                                    <% } %>
                                ">
                                    <%= p.statusLabel %>
                                </span>
                            </td>

                            <!-- Visto -->
                            <td class="px-4 py-3 text-center">
                                <% if (p.lastViewedLabel) { %>
                                    <div class="flex flex-col items-center group/visto">
                                        <div class="flex items-center gap-1.5 px-2 py-0.5 bg-gray-50 rounded text-[9px] font-black text-gray-900 uppercase tracking-tighter border border-gray-200 shadow-sm transition-all group-hover/visto:bg-[#31713D] group-hover/visto:text-white group-hover/visto:border-[#31713D]">
                                            <i data-lucide="eye" class="w-2.5 h-2.5"></i>
                                            Visto
                                        </div>
                                        <span class="text-[8px] font-bold text-gray-400 mt-1 uppercase tracking-tight opacity-80 group-hover/visto:opacity-100"><%= p.lastViewedLabel %></span>
                                    </div>
                                <% } else { %>
                                    <div class="flex flex-col items-center opacity-20 grayscale">
                                        <i data-lucide="eye-off" class="w-3.5 h-3.5 text-gray-400"></i>
                                        <span class="text-[7px] font-black uppercase mt-1 tracking-widest">Pendiente</span>
                                    </div>
                                <% } %>
                            </td>

                            <!-- Revisión (is_editing) -->
                            <td class="px-4 py-3 text-center">
                                <label class="relative inline-flex items-center cursor-pointer" onclick="event.stopPropagation()">
                                    <input type="checkbox" 
                                           class="sr-only peer" 
                                           <%= p.is_editing ? 'checked' : '' %>
                                           onchange="toggleRevision(<%= p.id %>, this.checked)">
                                    <div class="w-8 h-4 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-[#31713D]"></div>
                                </label>
                            </td>

                            <!-- Acciones -->
                            <td class="px-4 py-2 text-right">
                                <div class="flex flex-wrap justify-end gap-1.5 items-center print-hidden">
                                    <!-- Ver como Cliente -->
                                    <a href="/p/<%= p.unique_hash %>" 
                                       target="_blank"
                                       class="p-1.5 text-black hover:bg-gray-100 rounded-lg transition-colors border border-gray-200 inline-flex items-center" 
                                       title="Ver propuesta como cliente (nueva ventana)"
                                       onclick="event.stopPropagation()">
                                        <i data-lucide="eye" class="w-4 h-4"></i>
                                    </a>
                                    <% if (p.status === 'Anulada') { %>
                                        <span class="px-2 py-0.5 rounded-lg text-[10px] font-semibold border border-red-200 bg-red-50 text-red-700">
                                            Anulada
                                        </span>
                                    <% } else { %>
                                        <!-- Duplicar -->
                                        <form method="POST" action="/proposal/<%= p.id %>/duplicate" style="display: inline;">
                                            <button type="submit" 
                                                    class="p-1.5 text-black hover:bg-gray-100 rounded-lg transition-colors border border-gray-200 inline-flex items-center" 
                                                    title="Duplicar propuesta"
                                                    onclick="event.stopPropagation(); return confirm('¿Duplicar esta propuesta?')">
                                                <i data-lucide="copy" class="w-4 h-4"></i>
                                            </button>
                                        </form>
                                        <!-- Eliminar (requiere confirmación explícita) -->
                                        <form method="POST" action="/proposal/<%= p.id %>/delete" style="display: inline;" onsubmit="return false;">
                                                <button type="button" 
                                                    class="p-1.5 text-black hover:bg-gray-100 rounded-lg transition-colors border border-gray-200 inline-flex items-center" 
                                                    title="Eliminar propuesta"
                                                    onclick="event && event.stopPropagation(); openDeleteModal(this.closest('form'))">
                                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination (future) -->
            <% if (pageNumber > 1 || proposals.length === 10) { %>
            <div id="pagination-controls" class="px-6 py-4 border-t border-gray-200 flex justify-between items-center text-sm text-gray-600 bg-gray-50/50">
                <% if (pageNumber > 1) { %>
                    <a href="?status=<%= currentFilter %>&search=<%= searchTerm %>&page=<%= pageNumber - 1 %>" 
                       class="inline-flex items-center gap-1 text-[#31713D] hover:text-[#24552E] font-bold uppercase text-[10px] tracking-widest bg-white px-3 py-1.5 rounded border border-gray-200 shadow-sm transition-all">
                        <i data-lucide="chevron-left" class="w-3 h-3"></i> Anterior
                    </a>
                <% } else { %>
                    <span></span>
                <% } %>
                
                <span class="font-medium text-gray-400 text-[10px] uppercase tracking-widest">Página <%= pageNumber %></span>
                
                <% if (proposals.length === 10) { %>
                    <a href="?status=<%= currentFilter %>&search=<%= searchTerm %>&page=<%= pageNumber + 1 %>" 
                       class="inline-flex items-center gap-1 text-[#31713D] hover:text-[#24552E] font-bold uppercase text-[10px] tracking-widest bg-white px-3 py-1.5 rounded border border-gray-200 shadow-sm transition-all">
                        Siguiente <i data-lucide="chevron-right" class="w-3 h-3"></i>
                    </a>
                <% } else { %>
                    <span class="w-20"></span>
                <% } %>
            </div>
            <% } %>
        <% } %>
    </div>
</main>

<!-- Sidebar de Mensajes Pendientes -->
<div id="sidebar-pending" class="fixed inset-y-0 right-0 w-96 bg-white shadow-2xl z-[100] transform translate-x-full transition-transform duration-300 ease-in-out border-l border-gray-200 flex flex-col print:hidden">
    <div class="p-4 border-b border-gray-100 flex items-center justify-between bg-gray-50">
        <div>
            <h2 class="text-base font-black text-gray-900 uppercase tracking-widest">Chat Pendientes</h2>
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter">Mensajes no leídos de clientes</p>
        </div>
        <button onclick="closePendingSidebar()" class="p-2 hover:bg-white rounded-lg transition-colors">
            <i data-lucide="x" class="w-5 h-5 text-gray-400"></i>
        </button>
    </div>

    <div id="sidebar-content" class="flex-1 overflow-y-auto p-4 space-y-4">
        <!-- Loader -->
        <div id="sidebar-loader" class="flex flex-col items-center justify-center py-12 text-gray-400">
            <i data-lucide="loader-2" class="w-8 h-8 animate-spin mb-2"></i>
            <span class="text-xs font-bold uppercase tracking-widest">Cargando mensajes...</span>
        </div>
        
        <!-- Contenedor de Mensajes -->
        <div id="pending-messages-container" class="space-y-3 hidden"></div>

        <!-- Empty State sidebar -->
        <div id="sidebar-empty" class="hidden flex flex-col items-center justify-center py-12 text-center">
            <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                <i data-lucide="check-circle" class="w-8 h-8 text-green-500 opacity-20"></i>
            </div>
            <p class="text-sm font-black text-gray-900 uppercase">¡Al día!</p>
            <p class="text-[10px] text-gray-400 font-bold max-w-[200px] mt-1 italic">No tienes mensajes pendientes de respuesta.</p>
        </div>
    </div>
</div>

<!-- Overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/20 backdrop-blur-sm z-[90] hidden transition-opacity duration-300 opacity-0" onclick="closePendingSidebar()"></div>

<!-- Modal de confirmación de borrado -->
<div id="confirm-delete-modal" class="fixed inset-0 z-[110] hidden items-center justify-center px-4 py-6">
    <div id="confirm-delete-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
    <div class="relative bg-white rounded-xl shadow-lg w-full max-w-md mx-auto z-20 overflow-hidden">
        <div class="p-6">
            <div class="flex items-start gap-4">
                <div class="flex-shrink-0">
                    <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center border border-red-100">
                        <i data-lucide="trash-2" class="w-5 h-5 text-red-600"></i>
                    </div>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-black text-gray-900">Confirmar eliminación</h3>
                    <p class="text-sm text-gray-500 mt-1">Esta acción eliminará la propuesta y todos sus archivos relacionados. No se puede deshacer.</p>
                </div>
            </div>
        </div>
        <div class="px-6 pb-6 flex items-center justify-end gap-3 bg-gray-50">
            <button id="btn-cancel-delete" class="bg-white border border-gray-200 px-4 py-2 rounded-lg font-bold text-sm text-gray-700 hover:bg-gray-100" onclick="closeDeleteModal()">Cancelar</button>
            <button id="btn-confirm-delete" class="bg-red-600 text-white px-4 py-2 rounded-lg font-black text-sm hover:bg-red-700">Eliminar</button>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script src="/js/utils.js"></script>
<script src="/js/dashboard-search.js"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<script>
// Forzar inicialización de Lucide al cargar la página
function initIcons() {
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    } else {
        console.error('Lucide no cargó correctamente');
    }
}

// sidebar Logic (Definido globalmente para que el header pueda llamarlo)
window.openPendingSidebar = async function() {
    const sidebar = document.getElementById('sidebar-pending');
    console.log('Opening sidebar...', sidebar);
    const overlay = document.getElementById('sidebar-overlay');
    const container = document.getElementById('pending-messages-container');
    const loader = document.getElementById('sidebar-loader');
    const empty = document.getElementById('sidebar-empty');

    if (!sidebar) return;

    // Mostrar sidebar
    sidebar.classList.remove('translate-x-full');
    overlay.classList.remove('hidden');
    setTimeout(() => overlay.classList.add('opacity-100'), 10);

    // Fetch mensajes
    try {
        loader.classList.remove('hidden');
        container.classList.add('hidden');
        empty.classList.add('hidden');

        const response = await fetch('/api/dashboard/pending-messages');
        if (!response.ok) {
            throw new Error(`Error HTTP: ${response.status}`);
        }
        
        const data = await response.json();

        if (data.success && data.messages && data.messages.length > 0) {
            container.innerHTML = '';
            data.messages.forEach(group => {
                const card = document.createElement('a');
                card.href = `/proposal/${group.proposal_id}/edit`;
                card.className = "block bg-white border border-black rounded-xl p-2.5 hover:shadow-md transition-all group relative overflow-hidden";
                
                // Hilo de conversación
                let chatHistoryHtml = '';
                
                // 1. Burbuja Comercial (si existe) - Contexto
                if (group.last_commercial_msg) {
                    chatHistoryHtml += `
                        <div class="flex justify-end mb-1">
                            <div class="bg-gray-50 border border-gray-200 rounded-lg rounded-tr-none px-2 py-1 max-w-[90%] relative">
                                <span class="absolute -top-2.5 right-1 text-[7px] font-black text-gray-400 uppercase">Tú</span>
                                <p class="text-[9px] text-gray-500 font-medium leading-[1.1] italic line-clamp-1">"${group.last_commercial_msg.body}"</p>
                            </div>
                        </div>
                    `;
                }

                // 2. Burbujas de Cliente
                if (group.latest_messages && group.latest_messages.length > 0) {
                    group.latest_messages.forEach(m => {
                        chatHistoryHtml += `
                            <div class="flex justify-start mb-0.5 last:mb-0">
                                <div class="bg-[#31713D]/5 border border-[#31713D]/20 rounded-lg rounded-tl-none px-2 py-1 max-w-[90%]">
                                    <p class="text-[10px] text-gray-900 font-bold leading-[1.1]">"${m.body}"</p>
                                </div>
                            </div>
                        `;
                    });
                }

                card.innerHTML = `
                    <div class="flex flex-col">
                        <div class="flex items-center justify-between mb-1.5">
                            <div class="flex items-center gap-1">
                                <span class="bg-black text-white text-[8px] font-black px-1.5 rounded">REF</span>
                                <span class="text-[10px] font-black text-black uppercase tracking-tighter">${group.custom_ref || 'PEND'}</span>
                                ${group.unread_count > 1 ? `<span class="bg-[#31713D] text-white text-[8px] font-black w-3.5 h-3.5 flex items-center justify-center rounded-full leading-none">${group.unread_count}</span>` : ''}
                            </div>
                            <span class="text-[8px] font-bold text-gray-400 uppercase">${group.latest_messages[0].time}</span>
                        </div>
                        
                        <div class="mb-1.5 px-0.5">
                            <h4 class="text-[11px] font-black text-[#31713D] uppercase truncate leading-none">
                                ${group.client_name}
                                ${group.selected_venue ? `<span class="text-[9px] font-bold text-gray-400 normal-case tracking-tight ml-1.5 opacity-80">· ${group.selected_venue}</span>` : ''}
                            </h4>
                        </div>

                        <div class="flex flex-col bg-gray-50/30 rounded-lg p-1.5 border border-gray-100">
                            ${chatHistoryHtml}
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
            
            container.classList.remove('hidden');
            if (window.lucide) lucide.createIcons();
        } else {
            empty.classList.remove('hidden');
        }
    } catch (err) {
        console.error('Error fetching pending messages:', err);
        container.innerHTML = `<p class="text-xs text-red-500 text-center font-bold uppercase">Error al cargar mensajes</p>`;
        container.classList.remove('hidden');
    } finally {
        loader.classList.add('hidden');
    }
};

window.closePendingSidebar = function() {
    const sidebar = document.getElementById('sidebar-pending');
    const overlay = document.getElementById('sidebar-overlay');
    
    if (!sidebar) return;
    
    sidebar.classList.add('translate-x-full');
    overlay.classList.remove('opacity-100');
    setTimeout(() => overlay.classList.add('hidden'), 300);
};

document.addEventListener('DOMContentLoaded', initIcons);
window.addEventListener('load', initIcons);
// Reintento extra por si acaso
setTimeout(initIcons, 500);
setTimeout(initIcons, 2000);

// Cambiar estado de edición (Revisión)
async function toggleRevision(id, isChecked) {
    try {
        const response = await fetch(`/api/proposals/${id}/toggle-editing`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ is_editing: isChecked })
        });
        
        const data = await response.json();
        if (!data.success) {
            alert('Error al actualizar el estado de revisión');
            // Revertir el checkbox si falla
            location.reload();
        }
    } catch (err) {
        console.error('Error toggleRevision:', err);
        alert('Error de conexión');
        location.reload();
    }
}

// Copiar a portapapeles
function copyToClipboard(text) {
  const baseUrl = '<%= user?.domain || 'https://propuesta.micecatering.eu' %>';
  const fullUrl = baseUrl + text;
  
  navigator.clipboard.writeText(fullUrl).then(() => {
    // Show toast notification
    const toast = document.createElement('div');
    toast.className = 'fixed bottom-4 right-4 bg-green-600 text-white px-4 py-2 rounded-lg shadow-lg z-50';
    toast.textContent = 'Enlace copiado: ' + fullUrl;
    document.body.appendChild(toast);
    
    setTimeout(() => {
      toast.remove();
    }, 3000);
  }).catch(err => {
    console.error('Error al copiar:', err);
    alert('No se pudo copiar el enlace. Intenta nuevamente.');
  });
}
// Manejo de confirmación antes de eliminar
// Modal-driven delete flow
let _formToDelete = null;
function openDeleteModal(form) {
    _formToDelete = form;
    const modal = document.getElementById('confirm-delete-modal');
    if (!modal) {
        // Fallback to simple confirm
        if (!form) return false;
        if (!confirm('¿Estás seguro? Esta acción no se puede deshacer.')) return false;
        addConfirmAndSubmit(form);
        return;
    }
    modal.classList.remove('hidden');
    // prevent page scroll
    document.documentElement.style.overflow = 'hidden';
    // focus confirm button
    setTimeout(() => {
        const btn = document.getElementById('btn-confirm-delete');
        if (btn) btn.focus();
    }, 50);
}

function closeDeleteModal() {
    const modal = document.getElementById('confirm-delete-modal');
    if (modal) modal.classList.add('hidden');
    document.documentElement.style.overflow = '';
    _formToDelete = null;
}

function addConfirmAndSubmit(form) {
    if (!form) return;
    let existing = form.querySelector('input[name="confirm"]');
    if (!existing) {
        const inp = document.createElement('input');
        inp.type = 'hidden';
        inp.name = 'confirm';
        inp.value = 'yes';
        form.appendChild(inp);
    } else {
        existing.value = 'yes';
    }
    form.submit();
}

document.addEventListener('DOMContentLoaded', () => {
    const btnConfirm = document.getElementById('btn-confirm-delete');
    if (btnConfirm) {
        btnConfirm.addEventListener('click', () => {
            if (_formToDelete) addConfirmAndSubmit(_formToDelete);
            closeDeleteModal();
        });
    }
    // close modal with Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeDeleteModal();
    });
});

// Manejo de formularios inline (duplicar, eliminar)
document.querySelectorAll('form').forEach(form => {
    if (form.method === 'POST') {
        form.addEventListener('submit', function(e) {
            // Las validaciones ya están en los onclick de los botones
        });
    }
});

document.addEventListener('DOMContentLoaded', () => {
    if (window.lucide) {
        lucide.createIcons();
    }
});
