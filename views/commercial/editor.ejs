<script>
  /**
   * Toggle Modal Zoom (Full Screen)
   */
  function toggleModalZoom(modalId) {
    const modal = document.getElementById(modalId);
    if (!modal) return;
    const content = modal.querySelector('.bg-white, .max-w-xl, .max-w-4xl, .max-w-lg, .max-w-5xl, .max-w-3xl');
    if (!content) return;

    if (content.classList.contains('max-w-none')) {
      const prevClass = content.getAttribute('data-prev-max-w') || 'max-w-xl';
      content.classList.remove('max-w-none', 'w-[98vw]', 'h-[98vh]', 'rounded-none');
      content.classList.add(prevClass, 'rounded-none');
    } else {
      let currentMaxW = 'max-w-xl';
      ['max-w-xl', 'max-w-4xl', 'max-w-lg', 'max-w-5xl', 'max-w-3xl'].forEach(c => {
        if (content.classList.contains(c)) currentMaxW = c;
      });
      content.setAttribute('data-prev-max-w', currentMaxW);
      content.classList.remove(currentMaxW, 'rounded-none');
      content.classList.add('max-w-none', 'w-[98vw]', 'h-[98vh]', 'rounded-none');
    }
    if (window.lucide) lucide.createIcons();
  }

  /**
   * Click fuera del modal para cerrar
   */
  document.addEventListener('mousedown', function(e) {
    const modals = [
      'serviceModal', 
      'dishSelectorModal', 
      'itemModal', 
      'discountsModal', 
      'modal-venue-details'
    ];

    modals.forEach(id => {
      const modal = document.getElementById(id);
      if (modal && !modal.classList.contains('hidden')) {
        const content = modal.querySelector('.bg-white, .bg-gray-50, .max-w-3xl, .max-w-xl, .max-w-lg, .max-w-5xl');
        if (content && !content.contains(e.target)) {
          // Si el ID es especial, llamar a su función de cierre
          if (id === 'serviceModal') closeServiceModal();
          else if (id === 'dishSelectorModal') closeDishSelector();
          else if (id === 'itemModal') closeItemModal();
          else if (id === 'discountsModal') closeDiscountsModal();
          else if (id === 'modal-venue-details') {
             // Close venue modal (assuming closeVenueModal exists)
             modal.classList.add('hidden');
          }
          else modal.classList.add('hidden');
        }
      }
    });
  });
</script>

