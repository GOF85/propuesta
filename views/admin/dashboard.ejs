<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Administrativo - MICE Catering</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-gray-50">

<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-4 py-6">
    <%- include('../partials/flash-messages') %>

    <!-- Header Compacto -->
    <div class="mb-6">
        <div class="bg-white border border-gray-200 rounded-lg px-6 py-4 flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-green-50 rounded-lg">
                    <i data-lucide="settings" class="w-6 h-6 text-[#31713D]"></i>
                </div>
                <div>
                    <h1 class="text-xl font-bold text-gray-800">Panel Administrativo</h1>
                    <p class="text-gray-500 text-xs">Gestión de datos maestros y usuarios</p>
                </div>
            </div>
            <div class="text-right hidden sm:block">
                <div class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold text-gray-300">Última actualización</div>
                <div class="text-sm font-bold text-gray-700"><%= new Date().toLocaleTimeString('es-ES', {hour: '2-digit', minute: '2-digit'}) %></div>
            </div>
        </div>
    </div>

    <!-- Grid de Gestión Compacto -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

        <!-- USUARIOS Card -->
        <a href="/admin/users" class="bg-white rounded-lg border border-gray-200 p-4 hover:border-[#31713D] hover:shadow-md transition group">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gray-50 rounded flex items-center justify-center group-hover:bg-green-50 transition">
                    <i data-lucide="users" class="text-gray-400 group-hover:text-[#31713D] w-5 h-5"></i>
                </div>
                <div>
                    <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Usuarios</h2>
                    <div class="text-xl font-bold text-gray-800">Gestión</div>
                </div>
            </div>
        </a>

        <!-- VENUES Card -->
        <a href="/admin/venues" class="bg-white rounded-lg border border-gray-200 p-4 hover:border-[#31713D] hover:shadow-md transition group">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gray-50 rounded flex items-center justify-center group-hover:bg-green-50 transition">
                    <i data-lucide="building-2" class="text-gray-400 group-hover:text-[#31713D] w-5 h-5"></i>
                </div>
                <div>
                    <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Venues</h2>
                    <div class="text-xl font-bold text-gray-800"><%= totalVenues %></div>
                </div>
            </div>
        </a>

        <!-- DISHES Card -->
        <a href="/admin/dishes" class="bg-white rounded-lg border border-gray-200 p-4 hover:border-[#31713D] hover:shadow-md transition group">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gray-50 rounded flex items-center justify-center group-hover:bg-green-50 transition">
                    <i data-lucide="utensils" class="text-gray-400 group-hover:text-[#31713D] w-5 h-5"></i>
                </div>
                <div>
                    <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Platos</h2>
                    <div class="text-xl font-bold text-gray-800"><%= totalDishes %></div>
                </div>
            </div>
        </a>

        <!-- MENUS Card -->
        <a href="/admin/menus" class="bg-white rounded-lg border border-gray-200 p-4 hover:border-[#31713D] hover:shadow-md transition group">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gray-50 rounded flex items-center justify-center group-hover:bg-green-50 transition">
                    <i data-lucide="package" class="text-gray-400 group-hover:text-[#31713D] w-5 h-5"></i>
                </div>
                <div>
                    <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Gastronomía</h2>
                    <div class="text-xl font-bold text-gray-800">Menús</div>
                </div>
            </div>
        </a>

        <!-- IMAGES Card -->
        <a href="/admin/images" class="bg-white rounded-lg border border-gray-200 p-4 hover:border-[#31713D] hover:shadow-md transition group">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gray-50 rounded flex items-center justify-center group-hover:bg-green-50 transition">
                    <i data-lucide="image" class="text-gray-400 group-hover:text-[#31713D] w-5 h-5"></i>
                </div>
                <div>
                    <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Catálogo Maestro</h2>
                    <div class="text-xl font-bold text-gray-800">Imágenes</div>
                </div>
            </div>
        </a>

        <!-- SUSTAINABILITY Card -->
        <a href="/admin/sustainability" class="bg-white rounded-lg border border-gray-200 p-4 hover:border-[#31713D] hover:shadow-md transition group">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gray-50 rounded flex items-center justify-center group-hover:bg-green-50 transition">
                    <i data-lucide="leaf" class="text-gray-400 group-hover:text-[#31713D] w-5 h-5"></i>
                </div>
                <div>
                    <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Sostenibilidad</h2>
                    <div class="text-xl font-bold text-gray-800">Editar</div>
                </div>
            </div>
        </a>

        <!-- CATEGORIES Card -->
        <a href="/admin/categories" class="bg-white rounded-lg border border-gray-200 p-4 hover:border-[#31713D] hover:shadow-md transition group">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gray-50 rounded flex items-center justify-center group-hover:bg-green-50 transition">
                    <i data-lucide="list" class="text-gray-400 group-hover:text-[#31713D] w-5 h-5"></i>
                </div>
                <div>
                    <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Configuración</h2>
                    <div class="text-xl font-bold text-gray-800">Categorías</div>
                </div>
            </div>
        </a>

    </div>

    <!-- Acciones Rápidas Compactas -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
        <a href="/dashboard" class="flex items-center gap-3 p-3 bg-white border border-gray-300 rounded-lg hover:border-green-500 hover:shadow transition">
            <i data-lucide="bar-chart-3" class="w-6 h-6 text-[#31713D]"></i>
            <div class="flex-1">
                <div class="font-semibold text-gray-900 text-sm">Dashboard Comercial</div>
                <div class="text-xs text-gray-500">Gestión de propuestas</div>
            </div>
        </a>
        <a href="/" class="flex items-center gap-3 p-3 bg-white border border-gray-300 rounded-lg hover:border-green-500 hover:shadow transition">
            <i data-lucide="home" class="w-6 h-6 text-[#31713D]"></i>
            <div class="flex-1">
                <div class="font-semibold text-gray-900 text-sm">Inicio</div>
                <div class="text-xs text-gray-500">Página principal</div>
            </div>
        </a>
        <a href="/logout" class="flex items-center gap-3 p-3 bg-white border border-gray-300 rounded-lg hover:border-gray-500 hover:shadow transition">
            <i data-lucide="log-out" class="w-6 h-6 text-gray-700"></i>
            <div class="flex-1">
                <div class="font-semibold text-gray-900 text-sm">Cerrar Sesión</div>
                <div class="text-xs text-gray-500">Salir</div>
            </div>
        </a>
    </div>

</main>

<%- include('../partials/footer') %>

<script src="https://unpkg.com/lucide@latest"></script>
<script>
  lucide.createIcons();
</script>

</body>
</html>
