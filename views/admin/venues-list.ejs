<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Venues - MICE Catering Proposals</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Global Theme CSS -->
    <link rel="stylesheet" href="/css/theme.css">
    <link rel="stylesheet" href="/css/professional.css">
</head>
<body class="bg-gray-50">
    <%- include('../partials/header') %>

    <main class="min-h-screen">
        <div class="container mx-auto p-4 max-w-7xl">
  <!-- Header -->
  <div class="mb-4">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold flex items-center gap-2 text-gray-800">
          <i data-lucide="building-2" class="w-6 h-6 text-[#31713D]"></i>
          Gestión de Venues
        </h1>
        <p class="text-xs text-gray-500">Importa desde micecatering.com o crea manualmente</p>
      </div>
      <a href="/admin/venues/export" class="bg-[#31713D] hover:bg-[#24552E] text-white px-3 py-1.5 rounded text-sm transition flex items-center gap-2 shadow-sm">
        <i data-lucide="download" class="w-4 h-4"></i>
        <span>Exportar CSV</span>
      </a>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="flex gap-2 mb-4 flex-wrap">
    <button class="bg-[#31713D] hover:bg-[#24552E] text-white px-3 py-1.5 rounded text-sm transition flex items-center gap-2 shadow-sm" onclick="openVenueForm('new')">
      <i data-lucide="plus-circle" class="w-4 h-4"></i>
      <span>Crear Manual</span>
    </button>

    <button class="bg-[#31713D] hover:bg-[#24552E] text-white px-3 py-1.5 rounded text-sm transition flex items-center gap-2 shadow-sm"
            onclick="document.getElementById('import-csv').click()">
      <i data-lucide="file-up" class="w-4 h-4"></i>
      <span>Importar CSV</span>
    </button>

    <input type="file" id="import-csv" hidden accept=".csv" />
  </div>

  <!-- Status Messages -->
  <% if (locals.flash && locals.flash.success) { %>
    <div class="bg-green-50 border border-green-300 text-[#24552E] px-4 py-3 rounded mb-4 flex items-center gap-2">
      <i data-lucide="check-circle" class="w-5 h-5"></i>
      <%= locals.flash.success %>
    </div>
  <% } %>

  <% if (locals.flash && locals.flash.error) { %>
    <div class="bg-gray-100 border border-gray-400 text-gray-800 px-4 py-3 rounded mb-4 flex items-center gap-2">
      <i data-lucide="alert-circle" class="w-5 h-5"></i>
      <%= locals.flash.error %>
    </div>
  <% } %>

  <!-- Cola de URLs para scrape -->
  <div class="mb-8">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-bold flex items-center gap-2 text-gray-700 uppercase tracking-wider">
        <i data-lucide="list" class="w-4 h-4 text-orange-500"></i>
        Cola de Scraping (<span id="pending-count"><%= (locals.pendingScrapes || []).length %></span>)
      </h2>
      <div class="flex gap-2">
        <a href="/admin/venues/queue-template" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5 rounded text-xs flex items-center gap-2 transition border border-gray-300 font-bold" title="Descargar plantilla CSV">
          <i data-lucide="download" class="w-3.5 h-3.5"></i>
          Plantilla
        </a>
        
        <button onclick="document.getElementById('import-queue-csv').click()" class="bg-[#31713D] hover:bg-black text-white px-3 py-1.5 rounded text-xs flex items-center gap-2 transition shadow-sm font-bold">
          <i data-lucide="file-up" class="w-3.5 h-3.5"></i>
          Importar
        </button>
        <input type="file" id="import-queue-csv" hidden accept=".csv" onchange="importQueueCsv(this)" />

        <button onclick="scrapeAllPending()" class="bg-orange-600 hover:bg-black text-white px-3 py-1.5 rounded text-xs flex items-center gap-2 transition shadow-sm font-bold">
          <i data-lucide="play" class="w-3.5 h-3.5"></i>
          Scrapear todos
        </button>
      </div>
    </div>

    <!-- Formulario rápido de URL -->
    <div class="mb-4 bg-white p-3 rounded-lg border border-gray-200 shadow-sm flex gap-2">
      <div class="flex-1 relative">
        <i data-lucide="link" class="w-4 h-4 absolute left-3 top-2.5 text-gray-400"></i>
        <input type="url" id="quick-url-input" placeholder="Pega aquí la URL de micecatering.com..." 
               class="w-full pl-9 pr-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#31713D] focus:border-transparent outline-none transition" />
      </div>
      <button onclick="addUrlToQueue()" class="bg-[#31713D] text-white px-6 py-2 rounded-lg text-sm font-bold hover:bg-black transition shadow-sm flex items-center gap-2">
        <i data-lucide="plus" class="w-4 h-4"></i>
        Añadir
      </button>
    </div>

    <% if ((locals.pendingScrapes || []).length === 0) { %>
      <div id="no-pending-msg" class="text-center py-8 bg-white rounded-lg border border-dashed border-gray-300 text-gray-400 text-sm">
        <i data-lucide="link-2" class="w-8 h-8 mx-auto mb-2 opacity-20"></i>
        <p>No hay URLs en la cola de scrape. ¡Añade una para empezar!</p>
      </div>
    <% } %>
    
    <div id="pending-table-container" class="<%= (locals.pendingScrapes || []).length === 0 ? 'hidden' : '' %> bg-white rounded-lg border border-gray-200 overflow-hidden shadow-sm">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-50 border-b border-gray-200 text-gray-500 uppercase text-xs">
          <tr>
            <th class="px-4 py-3 font-semibold">URL de micecatering.com</th>
            <th class="px-4 py-3 font-semibold w-32 text-center">Estado</th>
            <th class="px-4 py-3 font-semibold text-right w-40">Acciones</th>
          </tr>
        </thead>
        <tbody id="pending-scrapes-body" class="divide-y divide-gray-100">
          <% (locals.pendingScrapes || []).forEach((item) => { %>
            <tr class="hover:bg-gray-50 transition-colors" data-id="<%= item.id %>">
              <td class="px-4 py-3 text-gray-600 truncate max-w-md font-mono text-[11px]" title="<%= item.url %>">
                <%= item.url %>
              </td>
              <td class="px-4 py-3 text-center">
                <% 
                  let badgeClass = 'bg-gray-100 text-gray-600';
                  if(item.status === 'pending') badgeClass = 'bg-amber-100 text-amber-700 border-amber-200';
                  if(item.status === 'completed') badgeClass = 'bg-green-100 text-green-700 border-green-200';
                  if(item.status === 'failed') badgeClass = 'bg-red-100 text-red-700 border-red-200';
                  if(item.status === 'processing') badgeClass = 'bg-blue-100 text-blue-700 animate-pulse';
                %>
                <span class="status-badge px-2.5 py-1 rounded-full text-[10px] font-bold border uppercase tracking-wider <%= badgeClass %>">
                  <%= item.status %>
                </span>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex justify-end gap-2">
                  <button onclick="scrapeSingleUrl(<%= item.id %>, '<%= item.url %>')" 
                          class="p-1.5 text-slate-900 hover:text-[#31713D] hover:bg-green-50 rounded-lg transition border border-transparent hover:border-green-200" title="Scrapear ahora">
                    <i data-lucide="download-cloud" class="w-4 h-4"></i>
                  </button>
                  <button onclick="deleteFromQueue(<%= item.id %>)" 
                          class="p-1.5 text-slate-900 hover:text-red-500 hover:bg-red-50 rounded-lg transition border border-transparent hover:border-red-200" title="Eliminar">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Venues ya registrados (listado inferior) -->
  <div>
    <h2 class="text-sm font-bold mb-3 flex items-center justify-between gap-2 text-gray-700 uppercase tracking-wider">
      <div class="flex items-center gap-2">
        <i data-lucide="database" class="w-4 h-4 text-[#31713D]"></i>
        Venues en Catálogo (<span id="venue-count-all"><%= (locals.venues || []).length %></span>)
      </div>
      <div class="relative w-64">
        <input type="text" id="venue-search-input" placeholder="Filtrar catálogo..." 
               class="bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg focus:ring-[#31713D] focus:border-[#31713D] block w-full pr-8 py-1.5 px-3">
        <div class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none">
          <i data-lucide="search" class="w-3 h-3 text-gray-400"></i>
        </div>
      </div>
    </h2>

    <% if ((locals.venues || []).length === 0) { %>
      <div class="text-center py-12 bg-white rounded-lg border border-dashed border-gray-300 text-gray-400 text-sm">
        <i data-lucide="building-2" class="w-12 h-12 mx-auto mb-3 opacity-10"></i>
        <p>No hay venues registrados en la base de datos.</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        <% (locals.venues || []).forEach((venue) => { %>
          <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition group">
            <div class="relative h-32 bg-gray-100 overflow-hidden">
              <% if (venue.images && venue.images.length > 0) { %>
                <img src="<%= venue.images[0] %>" alt="<%= venue.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm text-white text-[10px] px-2 py-0.5 rounded-full font-bold">
                  <%= venue.images.length %> fotos
                </div>
              <% } else { %>
                <div class="flex flex-col items-center justify-center h-full text-gray-300">
                  <i data-lucide="image-off" class="w-8 h-8 opacity-20"></i>
                  <span class="text-[10px] uppercase font-bold tracking-widest mt-2">Sin imágenes</span>
                </div>
              <% } %>
            </div>
            <div class="p-4">
              <div class="flex justify-between items-start gap-3 mb-2">
                <h3 class="text-sm font-bold text-gray-900 leading-snug line-clamp-2 min-h-[40px]" title="<%= venue.name %>">
                  <%= venue.name %>
                </h3>
                <div class="flex gap-1 shrink-0">
                  <button class="text-black hover:text-[#31713D] hover:bg-green-50 p-1.5 rounded-lg transition"
                          onclick="openVenueForm('edit', '<%= venue.id %>')" title="Editar">
                    <i data-lucide="edit-3" class="w-4 h-4"></i>
                  </button>
                  <button class="text-black hover:text-red-500 hover:bg-red-50 p-1.5 rounded-lg transition"
                          onclick="deleteVenue('<%= venue.id %>', '<%= venue.name %>')" title="Eliminar">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                </div>
              </div>
              <% if (venue.address) { %>
                <p class="text-[11px] text-gray-500 flex items-center gap-2 line-clamp-1">
                  <i data-lucide="map-pin" class="w-3 h-3 text-red-400"></i>
                  <%= venue.address %>
                </p>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

<!-- Modal: Formulario Manual -->
<div id="venue-form-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl max-h-screen overflow-y-auto">
    <div class="sticky top-0 bg-white border-b p-4 flex justify-between items-center">
      <h2 id="form-title" class="text-xl font-bold flex items-center gap-2">
        <i data-lucide="plus-circle" class="w-5 h-5"></i>
        Crear Venue
      </h2>
      <button onclick="closeVenueForm()" class="text-gray-500 hover:text-gray-700">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>

    <div class="p-6">
      <form id="venue-form" onsubmit="submitVenueForm(event)">
        <!-- Nombre -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
          <input type="text" id="venue-name" name="name" required class="w-full px-3 py-2 border border-gray-300 rounded" />
        </div>
        <!-- Descripción -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
          <textarea id="venue-description" name="description" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded"></textarea>
        </div>
        <!-- Dirección -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
          <input type="text" id="venue-address" name="address" class="w-full px-3 py-2 border border-gray-300 rounded" />
        </div>
        <!-- URL Externa -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">URL Externa</label>
          <input type="url" id="venue-external-url" name="external_url" class="w-full px-3 py-2 border border-gray-300 rounded" />
        </div>
        <div class="flex gap-3 justify-end">
          <button type="button" onclick="closeVenueForm()" class="px-4 py-2 bg-gray-300 rounded">Cancelar</button>
          <button type="submit" class="px-4 py-2 bg-[#31713D] text-white rounded">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  let formMode = 'new';
  let editingVenueId = null;

  function openVenueForm(mode, id) {
    formMode = mode;
    editingVenueId = id;
    const modal = document.getElementById('venue-form-modal');
    if (mode === 'edit') {
      document.getElementById('form-title').innerText = 'Editar Venue';
      fetch('/api/venues/' + id).then(r => r.json()).then(data => {
        if (data.success) {
          document.getElementById('venue-name').value = data.venue.name;
          document.getElementById('venue-description').value = data.venue.description;
          document.getElementById('venue-address').value = data.venue.address;
          document.getElementById('venue-external-url').value = data.venue.external_url;
        }
      });
    } else {
      document.getElementById('form-title').innerText = 'Crear Venue';
      document.getElementById('venue-form').reset();
    }
    modal.classList.remove('hidden');
    // Click fuera para cerrar
    modal.onclick = function(e) {
      if (e.target === modal) closeVenueForm();
    };
    setTimeout(() => lucide.createIcons(), 100);
  }

  function closeVenueForm() {
    document.getElementById('venue-form-modal').classList.add('hidden');
  }

  async function submitVenueForm(e) {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    const url = formMode === 'edit' ? '/api/admin/venues/' + editingVenueId : '/api/admin/venues/manual';
    const res = await fetch(url, {
      method: formMode === 'edit' ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    if ((await res.json()).success) location.reload();
  }

  async function addUrlToQueue() {
    const input = document.getElementById('quick-url-input');
    const url = input.value.trim();
    if (!url) return;

    // Feedback visual
    const btn = event.currentTarget;
    const originalContent = btn.innerHTML;
    btn.innerHTML = '<i data-lucide="loader" class="w-4 h-4 animate-spin"></i>';
    lucide.createIcons();
    btn.disabled = true;

    try {
      const res = await fetch('/api/admin/venues/queue', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url })
      });
      const data = await res.json();
      if (data.success) {
        location.reload();
      } else {
        alert(data.error || 'Error al añadir URL');
        btn.innerHTML = originalContent;
        btn.disabled = false;
        lucide.createIcons();
      }
    } catch (e) {
      alert('Error en la conexión');
      btn.innerHTML = originalContent;
      btn.disabled = false;
      lucide.createIcons();
    }
  }

  async function importQueueCsv(input) {
    if (!input.files || input.files.length === 0) return;
    
    const formData = new FormData();
    formData.append('csvFile', input.files[0]);

    try {
      const res = await fetch('/api/admin/venues/queue/import', {
        method: 'POST',
        body: formData
      });
      const data = await res.json();
      if (data.success) {
        alert(data.message);
        location.reload();
      } else {
        alert('Error: ' + data.error);
      }
    } catch (e) {
      alert('Error en la conexión');
    }
    input.value = ''; // Reset
  }

  async function scrapeSingleUrl(id, url) {
    const row = document.querySelector('tr[data-id="' + id + '"]');
    const badge = row.querySelector('.status-badge');
    badge.textContent = 'processing...';
    try {
      const res = await fetch('/api/admin/venues/scrape-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url, queueId: id })
      });
      if ((await res.json()).success) location.reload();
      else badge.textContent = 'failed';
    } catch (e) { badge.textContent = 'failed'; }
  }

  async function scrapeAllPending() {
    const rows = Array.from(document.querySelectorAll('#pending-scrapes-body tr'))
      .filter(r => r.querySelector('.status-badge').textContent.includes('pending'));
    for (const r of rows) {
      await scrapeSingleUrl(r.dataset.id, r.querySelector('td').title);
    }
  }

  async function deleteFromQueue(id) {
    if (confirm('¿Eliminar?')) {
      await fetch('/api/admin/venues/queue/' + id, { method: 'DELETE' });
      location.reload();
    }
  }

  async function deleteVenue(id, name) {
    if (confirm('¿Eliminar ' + name + '?')) {
      await fetch('/api/admin/venues/' + id, { method: 'DELETE' });
      location.reload();
    }
  }
</script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>lucide.createIcons();</script>
</body>
</html>
